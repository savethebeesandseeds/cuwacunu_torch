      << ",\"leakage_authority\":false"
      << ",\"contract_identity_authority\":false"
      << ",\"digest\":"
      << json_quote(exposure::source_receipt_fact_digest(receipt)) << "}";
  return out.str();
}

[[nodiscard]] std::string source_receipt_facts_json(
