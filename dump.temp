             "resolved_anchor_index_begin=" +
                 std::to_string(begin) +
                 "\n"
                 "resolved_anchor_index_end=" +
                 std::to_string(end) +
                 "\n"
                 "source_input_length=2\n"
                 "source_future_length=1\n"
