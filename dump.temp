-----------------------------------
File:
  src/include/kikijyeba/marshal/tool_handler.h

marshal_operator_envelope_fields_json(...) emits:
  schema_version
  dispatch_state
  refusal_reasons
  warnings
  next_safe_actions
  authority
  observed
  evidence_refs
