rollout operator packet:
  tool = hero.marshal.rollout
  schema_version = kikijyeba.marshal.rollout.v2.5b
  requested_mode = request.requested_mode
  dispatch_state = blocked | prepared | executed
  next_safe_actions =
    - fix_rollout_request
    - run_replay_command_or_inspect
    - inspect_rollout_report
    - inspect_runtime_replay_failure
  top-level next_action is not emitted

