                                    "wave_first_anchor_key=1000\n"
                                    "wave_last_anchor_key=1099\n"
                                    "checkpoint_written=true\n"
                                    "checkpoint_path=" +
                                    checkpoint_name + "\n");
  write_text(dir / "representation.report",
