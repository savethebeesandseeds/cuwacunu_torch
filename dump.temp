       {"deficits", "plan_basis"},
       "plan_basis",
       "plans are advice over deficits and never execute runtime work",
       true,
       false,
       false,
       "per_plan_relevant_deficit",
       "per_row",
       "not_applicable",
       "any_plan_relevant_deficit",
       "any",
