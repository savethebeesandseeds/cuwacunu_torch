  static void append_string_list(std::ostringstream &oss, const char *key,
                                 const std::vector<std::string> &values) {
    oss << key << "=";
    for (std::size_t i = 0; i < values.size(); ++i) {
      if (i != 0) {
        oss << ",";
      }
      oss << values[i];
    }
    oss << "\n";
  }

