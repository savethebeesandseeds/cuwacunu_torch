  runtime.job_events.probe

input_representation_checkpoint =
  /cuwacunu/.runtime/benchmarks/synthetic_continuous_graph_v1/.runtime/cuwacunu_exec/components/wikimyei.representation.encoding.mtf_jepa_mae_vicreg/spawns/lbu_2999bf691561cd0b/jobs/train/train_core_mtf_jepa_mae_vicreg.train.channel_representation_mtf_jepa_mae_vicreg.attempt_000000/channel_representation.report.mtf_jepa_mae_vicreg.pt

