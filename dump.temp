      << ",\"split_policy_fingerprint\":"
      << json_quote(receipt.split_policy_fingerprint)
      << ",\"component_assembly_fingerprint\":"
      << json_quote(receipt.component_assembly_fingerprint)
      << ",\"target_component\":" << json_quote(receipt.target_component)
