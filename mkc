#!/usr/bin/env bash
set -euo pipefail

SCRIPT_PATH="${BASH_SOURCE[0]}"
if command -v readlink >/dev/null 2>&1; then
  RESOLVED_PATH="$(readlink -f -- "${SCRIPT_PATH}" 2>/dev/null || true)"
  if [[ -n "${RESOLVED_PATH}" ]]; then
    SCRIPT_PATH="${RESOLVED_PATH}"
  fi
fi

SCRIPT_DIR="$(cd -- "$(dirname -- "${SCRIPT_PATH}")" && pwd)"
ROOT_DIR="${MKC_ROOT:-${SCRIPT_DIR}}"

if [[ -d "/cuwacunu/src/main" ]]; then
  MAKE_DIR="/cuwacunu/src/main"
else
  MAKE_DIR="${ROOT_DIR}/src/main"
fi

if [[ ! -d "${MAKE_DIR}" ]]; then
  echo "mkc: missing make directory: ${MAKE_DIR}" >&2
  exit 1
fi

DEFAULT_JOBS=1
if command -v nproc >/dev/null 2>&1; then
  DEFAULT_JOBS="$(nproc)"
fi
MKC_JOBS="${MKC_JOBS:-${DEFAULT_JOBS}}"

if ! [[ "${MKC_JOBS}" =~ ^[0-9]+$ ]] || (( MKC_JOBS < 1 )); then
  echo "mkc: MKC_JOBS must be a positive integer (got '${MKC_JOBS}')" >&2
  exit 2
fi

PRODUCTION_TARGETS=(
  all
  hero
  board_hero
  tools
  config_hero
  clean
)

MAIN_BASE_TARGETS=(
  all
  clean
  hero
  board_hero
  tools
  config_hero
  tests
  test
  ta
  clean_tests
  parser
  dsl
  types
  exchange
  piaabo
  data
  iinuji
  iinuji_torch
  tsiemene
  iitepi
  https
  db
  jkimyei
  vicreg
  mdn
  expval
)

SRC_BRIDGE_TARGETS=(
  src_all
  src_modules
  src_lib-bundles
  src_build
  src_b
  src_mods
  src_m
  src_bundles
  src_pack
  src_test
  src_t
  src_tests
  src_main
  src_piaabo
  src_iitepi
  src_camahjucunu
  src_jkimyei
  src_wikimyei
  src_iinuji
  src_it
  src_pia
  src_cam
  src_jk
  src_wk
  src_ii
  src_clean
  src_clean_all
  src_c
  src_ccommon
  src_cdsl
  src_cdata
  src_cwiki
  src_clean_common
  src_clean_dsl
  src_clean_data
  src_clean_wikimyei
)

EXTRA_WORDS=(
  rules
  --rules
  production_rules
  targets
  --targets
  --help
  help
)

MAIN_ALIAS_TARGETS=()
for t in "${MAIN_BASE_TARGETS[@]}"; do
  MAIN_ALIAS_TARGETS+=("main_${t}")
done

list_test_targets() {
  local tests_bench_dir="${ROOT_DIR}/src/tests/bench"
  local f
  local name
  local -A seen=()

  if [[ ! -d "${tests_bench_dir}" ]]; then
    tests_bench_dir="${MAKE_DIR}/tests/bench"
  fi

  [[ -d "${tests_bench_dir}" ]] || return 0

  while IFS= read -r -d '' f; do
    name="$(basename "${f%.cpp}")"
    [[ -n "${seen[$name]+x}" ]] && continue
    seen[$name]=1
    printf '%s\n' "$name"
  done < <(find "${tests_bench_dir}" -type f -name 'test_*.cpp' -print0 2>/dev/null)
}

list_completion_words() {
  local include_test_targets="${1:-0}"
  local include_main_test_targets="${2:-0}"
  local -A seen=()
  local w

  for w in "${MAIN_BASE_TARGETS[@]}" "${MAIN_ALIAS_TARGETS[@]}" "${SRC_BRIDGE_TARGETS[@]}" "${EXTRA_WORDS[@]}"; do
    [[ -n "${seen[$w]+x}" ]] && continue
    seen[$w]=1
    printf '%s\n' "$w"
  done

  if [[ "${include_test_targets}" == "1" || "${include_main_test_targets}" == "1" ]]; then
    while IFS= read -r w; do
      if [[ "${include_test_targets}" == "1" ]]; then
        [[ -n "${seen[$w]+x}" ]] || { seen["$w"]=1; printf '%s\n' "$w"; }
      fi
      if [[ "${include_main_test_targets}" == "1" ]]; then
        [[ -n "${seen[main_$w]+x}" ]] || { seen["main_$w"]=1; printf 'main_%s\n' "$w"; }
      fi
    done < <(list_test_targets)
  fi
}

cmd_complete() {
  local line="${COMP_LINE:-}"
  local point="${COMP_POINT:-${#line}}"
  local cur
  local arg_index
  local include_test_targets=0
  local include_main_test_targets=0
  local -a words=()
  local candidate

  if (( point > ${#line} )); then
    point=${#line}
  fi

  line="${line:0:point}"
  read -r -a words <<< "$line"

  if [[ "$line" =~ [[:space:]]$ ]]; then
    cur=""
    arg_index=$((${#words[@]} - 1))
  else
    cur="${words[-1]:-}"
    arg_index=$((${#words[@]} - 2))
  fi

  if (( arg_index < 0 )); then
    arg_index=0
  fi

  # mkc accepts a single target argument; do not complete beyond that.
  if (( arg_index > 0 )); then
    return 0
  fi

  if [[ "$cur" == test* ]]; then
    include_test_targets=1
  fi
  if [[ "$cur" == main_test* ]]; then
    include_main_test_targets=1
  fi

  while IFS= read -r candidate; do
    [[ "$candidate" == "$cur"* ]] || continue
    printf '%s\n' "$candidate"
  done < <(list_completion_words "$include_test_targets" "$include_main_test_targets")
}

usage() {
  cat <<'EOF'
Usage:
  mkc
  mkc <target>
  mkc rules
  mkc targets
  mkc --help

Notes:
  - mkc runs exactly one target per invocation.
  - mkc runs make with -j$(nproc) by default.
  - Override jobs with MKC_JOBS=<N>.
  - Set MKC_SHOW_CMD=1 to print the dispatched make command.
  - "mkc all" maps to src_all (full src aggregate).
  - Use "mkc main_all" for runtime-only main aggregate.
  - Local aliases: main_<target> (same as local target in src/main/Makefile).
  - Root bridge aliases: src_<target> (delegates to src/Makefile).
  - Example: mkc all, mkc main_all, mkc board_hero, mkc src_all, mkc test_iitepi_board.
EOF
}

run_make() {
  local target="${1:-}"
  local cmd=(make --no-print-directory -j"${MKC_JOBS}" -C "${MAKE_DIR}")

  # UX default: "all" means full src aggregate (impl/modules + bundles), not
  # runtime-only main/all. Use main_all for runtime entrypoints.
  if [[ "${target}" == "all" ]]; then
    target="src_all"
  fi

  if [[ -n "${target}" ]]; then
    cmd+=("${target}")
  fi

  if [[ "${MKC_SHOW_CMD:-0}" == "1" ]]; then
    printf 'mkc:'
    printf ' %q' "${cmd[@]}"
    printf '\n' >&2
  fi

  exec "${cmd[@]}"
}

if [[ "${1:-}" == "__complete" ]]; then
  cmd_complete
  exit 0
fi

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" || "${1:-}" == "help" ]]; then
  usage
  exit 0
fi

if (( $# > 1 )); then
  echo "mkc: ambiguous invocation: '$*'" >&2
  echo "mkc accepts one target only. Example: mkc tests" >&2
  echo "Use local aliases (main_*) or src bridge aliases (src_*) when needed." >&2
  exit 2
fi

case "${1:-}" in
  rules|production_rules|--rules)
    printf '%s\n' "${PRODUCTION_TARGETS[@]}"
    ;;
  targets|--targets)
    make --no-print-directory -s -C "${MAKE_DIR}" targets | awk '/^[[:alnum:]_.-]+$/ {print}'
    exit "${PIPESTATUS[0]}"
    ;;
  "")
    run_make
    ;;
  *)
    run_make "$1"
    ;;
esac
