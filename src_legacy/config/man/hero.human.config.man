MAN_SPEC_VERSION = 1

[META]
MAN_ID = hero.human.config
TARGET_DSL = src/config/instructions/defaults/default.hero.human.dsl
TARGET_BNF = src/config/bnf/latent_lineage_state.authored.bnf
PRIMARY_DECODER = src/main/hero/hero_human_mcp.cpp
PRIMARY_VALIDATORS = src/main/hero/hero_human_mcp.cpp,src/impl/hero/human_hero/hero_human_tools.cpp

[FIELD marshal_hero_binary]
key = marshal_hero_binary
scope = hero human defaults
type = path_or_command
required = true
default = /cuwacunu/.build/hero/hero_marshal.mcp
range = executable path or PATH-resolved command name
allowed = absolute_or_relative path or bare command token
nuance = Marshal Hero MCP binary Human Hero invokes to inspect sessions and apply a signed governance resolution after a pending governance request

[FIELD operator_id]
key = operator_id
scope = hero human defaults
type = string
required = true
default = CHANGE_ME_OPERATOR
range = non-empty identifier
allowed = ASCII operator identifier
nuance = operator identity embedded into signed governance-resolution and summary-ack artifacts for audit and attribution; if left as CHANGE_ME_OPERATOR or empty, Human Hero auto-initializes it to <user>@<hostname> on first use and persists that back into default.hero.human.dsl; signing still fails unless the resulting identifier has a matching public key in Marshal Hero human_operator_identities

[FIELD operator_signing_ssh_identity]
key = operator_signing_ssh_identity
scope = hero human defaults
type = path
required = true
default = ../../secrets/real/human_operator_ed25519
range = readable unencrypted OpenSSH ssh-ed25519 identity path
allowed = absolute path or path resolved relative to default.hero.human.dsl
nuance = unencrypted OpenSSH ssh-ed25519 identity Human Hero uses to sign governance-resolution and summary-ack artifacts before asking Marshal Hero to apply them; the matching public key must be registered for operator_id in Marshal Hero human_operator_identities

[NOTE HUMAN_ATTESTATION_CHAIN]
scope = hero human defaults
text = Human Hero signs with operator_signing_ssh_identity, while Marshal Hero verifies that detached signature against the public key resolved from operator_id in human_operator_identities from default.hero.marshal.dsl before a pending governance resolution may take effect.

[NOTE OPERATOR_ID_BOOTSTRAP]
scope = hero human defaults
text = On first Human Hero use, operator_id is auto-initialized to <user>@<hostname> if it is still CHANGE_ME_OPERATOR or empty. This bootstrap does not replace the need to register the matching public key in human_operator_identities.

[RULE OPERATOR_ID_CONFIGURED]
id = OPERATOR_ID_CONFIGURED
applies_to = operator_id
severity = error
when = operator_id == empty or operator_id == CHANGE_ME_OPERATOR
message = operator_id must be bootstrapped or set to a real operator identifier before Human Hero can sign a governance resolution or summary acknowledgment.

[RULE OPERATOR_IDENTITY_REGISTERED]
id = OPERATOR_IDENTITY_REGISTERED
applies_to = operator_id,operator_signing_ssh_identity
severity = error
when = operator_id has no matching public key entry in human_operator_identities or operator_signing_ssh_identity does not match that recorded public key
message = operator_id and operator_signing_ssh_identity must match an entry in Marshal Hero human_operator_identities before Marshal Hero can apply a human resolution.
