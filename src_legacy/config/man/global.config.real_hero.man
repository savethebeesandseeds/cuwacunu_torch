MAN_SPEC_VERSION = 1

[META]
MAN_ID = global.config.real_hero
TARGET_DSL = src/config/.config
TARGET_BNF = src/impl/iitepi/config_space_t.cpp (INI-like parser)
PRIMARY_DECODER = src/impl/iitepi/config_space_t.cpp
PRIMARY_VALIDATORS = src/impl/iitepi/config_space_t.cpp,src/include/hero/config_hero/hero.config.h

[ENUM REAL_HERO.mode]
key = REAL_HERO.mode
values = openai,selfhosted

[FIELD REAL_HERO.mode]
key = mode
scope = REAL_HERO section
type = enum
required = true
default = openai
range = one token
allowed = openai,selfhosted
nuance = selfhosted is parsed but rejected at startup; only openai is currently supported

[FIELD REAL_HERO.transport]
key = transport
scope = REAL_HERO section
type = enum
required = true
default = curl
range = one token
allowed = curl
nuance = current implementation is curl-only

[FIELD REAL_HERO.OPENAI_api_filename]
key = OPENAI_api_filename
scope = REAL_HERO section
type = path
required = true
default = /cuwacunu/src/config/secrets/real/openai.key
range = non-empty path
allowed = absolute_or_relative path
nuance = should reference secured key material file, not inline plaintext

[FIELD REAL_HERO.endpoint]
key = endpoint
scope = REAL_HERO section
type = string
required = true
default = https://api.openai.com/v1/responses
range = non-empty URL
allowed = HTTPS URL
nuance = active endpoint for mode=openai

[FIELD REAL_HERO.config_hero_dsl_filename]
key = config_hero_dsl_filename
scope = REAL_HERO section
type = path
required = true
default = /cuwacunu/src/config/instructions/defaults/default.hero.config.dsl
range = non-empty path
allowed = absolute_or_relative path
nuance = deterministic Config HERO runtime DSL file used by hero_config.mcp

[FIELD REAL_HERO.hashimyei_hero_dsl_filename]
key = hashimyei_hero_dsl_filename
scope = REAL_HERO section
type = path
required = true
default = /cuwacunu/src/config/instructions/defaults/default.hero.hashimyei.dsl
range = non-empty path
allowed = absolute_or_relative path
nuance = deterministic Hashimyei HERO defaults DSL used by hero_hashimyei.mcp

[FIELD REAL_HERO.human_hero_dsl_filename]
key = human_hero_dsl_filename
scope = REAL_HERO section
type = path
required = true
default = /cuwacunu/src/config/instructions/defaults/default.hero.human.dsl
range = non-empty path
allowed = absolute_or_relative path
nuance = deterministic Human HERO defaults DSL used by hero_human.mcp

[FIELD REAL_HERO.lattice_hero_dsl_filename]
key = lattice_hero_dsl_filename
scope = REAL_HERO section
type = path
required = true
default = /cuwacunu/src/config/instructions/defaults/default.hero.lattice.dsl
range = non-empty path
allowed = absolute_or_relative path
nuance = deterministic Lattice HERO defaults DSL used by hero_lattice.mcp

[FIELD REAL_HERO.marshal_hero_dsl_filename]
key = marshal_hero_dsl_filename
scope = REAL_HERO section
type = path
required = true
default = /cuwacunu/src/config/instructions/defaults/default.hero.marshal.dsl
range = non-empty path
allowed = absolute_or_relative path
nuance = deterministic Marshal HERO defaults DSL used by hero_marshal.mcp

[FIELD REAL_HERO.runtime_hero_dsl_filename]
key = runtime_hero_dsl_filename
scope = REAL_HERO section
type = path
required = true
default = /cuwacunu/src/config/instructions/defaults/default.hero.runtime.dsl
range = non-empty path
allowed = absolute_or_relative path
nuance = deterministic Runtime HERO defaults DSL used by hero_runtime.mcp

[RULE REAL_HERO_MODE_ALLOWED]
id = REAL_HERO_MODE_ALLOWED
applies_to = REAL_HERO.mode
severity = error
when = mode not in {openai,selfhosted}
message = REAL_HERO.mode must be openai or selfhosted

[RULE REAL_HERO_SELFHOSTED_FAILFAST]
id = REAL_HERO_SELFHOSTED_FAILFAST
applies_to = REAL_HERO.mode
severity = error
when = mode == selfhosted
message = REAL_HERO.mode=selfhosted is not supported yet; use mode=openai.

[RULE REAL_HERO_TRANSPORT]
id = REAL_HERO_TRANSPORT
applies_to = REAL_HERO.mode,REAL_HERO.transport
severity = error
when = mode == openai and transport != curl
message = REAL_HERO.transport must be curl in openai mode
