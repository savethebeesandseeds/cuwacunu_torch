#ifndef HERO_LATTICE_TOOL
#error                                                                         \
    "HERO_LATTICE_TOOL(NAME, DESCRIPTION, INPUT_SCHEMA_JSON, HANDLER) must be defined before including hero_lattice_tools.def"
#endif

HERO_LATTICE_TOOL(
    "hero.lattice.list_facts",
    "List available assembled fact bundles. Without canonical_path it lists "
    "latest fact summaries keyed by canonical_path; with canonical_path it "
    "lists available wave contexts for that fact",
    "{\"type\":\"object\",\"properties\":{\"canonical_path\":{\"type\":"
    "\"string\"},\"limit\":{\"type\":\"integer\"},\"offset\":{\"type\":"
    "\"integer\"}},\"additionalProperties\":false}",
    handle_tool_list_facts)
HERO_LATTICE_TOOL(
    "hero.lattice.get_fact",
    "Fetch the assembled complete fact bundle for a canonical_path locator. "
    "Returned fact bundles foreground canonical_path and context, default to "
    "the latest bundle, and only use wave_cursor when a historical context is "
    "explicitly requested",
    "{\"type\":\"object\",\"properties\":{\"canonical_path\":{\"type\":"
    "\"string\"},\"wave_cursor\":{\"type\":\"string\"}},\"required\":["
    "\"canonical_path\"],\"additionalProperties\":false}",
    handle_tool_get_fact)
HERO_LATTICE_TOOL(
    "hero.lattice.list_views",
    "List derived view kinds available from the lattice query engine without "
    "materializing their transport payloads",
    "{\"type\":\"object\",\"properties\":{},\"additionalProperties\":false}",
    handle_tool_list_views)
HERO_LATTICE_TOOL(
    "hero.lattice.get_view",
    "Fetch a derived view transport. entropic_capacity_comparison requires "
    "wave_cursor; family_evaluation_report requires canonical_path plus "
    "component_compatibility_sha256_hex and defaults to the latest coherent "
    "evidence bundle unless wave_cursor is provided",
    "{\"type\":\"object\",\"properties\":{\"view_kind\":{\"type\":\"string\"},"
    "\"canonical_path\":{\"type\":\"string\"},\"wave_cursor\":{\"type\":"
    "\"string\"},\"contract_hash\":{\"type\":\"string\"},\"component_"
    "compatibility_sha256_hex\":{\"type\":\"string\"}},\"required\":[\"view_"
    "kind\"],\"additionalProperties\":false}",
    handle_tool_get_view)
HERO_LATTICE_TOOL(
    "hero.lattice.browser_tree",
    "Return a fast family -> project -> member browser tree summary for the F3 "
    "lattice view without forcing a store-wide sync",
    "{\"type\":\"object\",\"properties\":{},\"additionalProperties\":false}",
    handle_tool_browser_tree)
HERO_LATTICE_TOOL(
    "hero.lattice.browser_detail",
    "Return lazy detail for one selected lattice browser node. kind=family "
    "requires family; kind=project requires project_path; kind=member requires "
    "canonical_path",
    "{\"type\":\"object\",\"properties\":{\"kind\":{\"type\":\"string\"},"
    "\"family\":{\"type\":\"string\"},\"project_path\":{\"type\":\"string\"},"
    "\"canonical_path\":{\"type\":\"string\"}},\"required\":[\"kind\"],"
    "\"additionalProperties\":false}",
    handle_tool_browser_detail)
HERO_LATTICE_TOOL(
    "hero.lattice.refresh",
    "Rebuild the lattice fact catalog. Set reingest=true to rescan emitted "
    "runtime .lls facts from store_root before querying",
    "{\"type\":\"object\",\"properties\":{\"reingest\":{\"type\":\"boolean\"}},"
    "\"additionalProperties\":false}",
    handle_tool_refresh)
