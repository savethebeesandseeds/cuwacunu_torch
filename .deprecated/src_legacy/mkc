#!/usr/bin/env bash
set -euo pipefail

SCRIPT_PATH="${BASH_SOURCE[0]}"
if command -v readlink >/dev/null 2>&1; then
  RESOLVED_PATH="$(readlink -f -- "${SCRIPT_PATH}" 2>/dev/null || true)"
  if [[ -n "${RESOLVED_PATH}" ]]; then
    SCRIPT_PATH="${RESOLVED_PATH}"
  fi
fi

SCRIPT_DIR="$(cd -- "$(dirname -- "${SCRIPT_PATH}")" && pwd)"
ROOT_DIR="${MKC_ROOT:-${SCRIPT_DIR}}"

if [[ -d "/cuwacunu/src" ]]; then
  SRC_MAKE_DIR="/cuwacunu/src"
  MAIN_MAKE_DIR="/cuwacunu/src/main"
else
  SRC_MAKE_DIR="${ROOT_DIR}/src"
  MAIN_MAKE_DIR="${ROOT_DIR}/src/main"
fi

if [[ ! -d "${SRC_MAKE_DIR}" ]]; then
  echo "mkc: missing src make directory: ${SRC_MAKE_DIR}" >&2
  exit 1
fi

if [[ ! -d "${MAIN_MAKE_DIR}" ]]; then
  echo "mkc: missing main make directory: ${MAIN_MAKE_DIR}" >&2
  exit 1
fi

DEFAULT_JOBS=1
if command -v nproc >/dev/null 2>&1; then
  DEFAULT_JOBS="$(nproc)"
fi
MKC_JOBS="${MKC_JOBS:-${DEFAULT_JOBS}}"

if ! [[ "${MKC_JOBS}" =~ ^[0-9]+$ ]] || (( MKC_JOBS < 1 )); then
  echo "mkc: MKC_JOBS must be a positive integer (got '${MKC_JOBS}')" >&2
  exit 2
fi

PRODUCTION_TARGETS=(
  lib
  link
  install
  all
  hero
  runtime_hero
  tools
  config_hero
  clean
)

SRC_TARGETS=(
  lib
  link
  install
  modules
  lib-bundles
  clean
  clean_common
  clean_dsl
  clean_data
  clean_wikimyei
)

MAIN_BASE_TARGETS=(
  all
  link
  install
  clean
  hero
  runtime_hero
  tools
  config_hero
  tests
  test
  ta
  clean_tests
  parser
  dsl
  types
  exchange
  piaabo
  data
  iinuji
  iinuji_torch
  tsiemene
  iitepi
  https
  db
  jkimyei
  vicreg
  mdn
  expval
)

EXTRA_WORDS=(
  rules
  --rules
  production_rules
  targets
  --targets
  --help
  help
)


list_test_targets() {
  local tests_bench_dir="${ROOT_DIR}/src/tests/bench"
  local f
  local name
  local -A seen=()

  if [[ ! -d "${tests_bench_dir}" ]]; then
    tests_bench_dir="${MAIN_MAKE_DIR}/../tests/bench"
  fi

  [[ -d "${tests_bench_dir}" ]] || return 0

  while IFS= read -r -d '' f; do
    name="$(basename "${f%.cpp}")"
    [[ -n "${seen[$name]+x}" ]] && continue
    seen[$name]=1
    printf '%s\n' "$name"
  done < <(find "${tests_bench_dir}" -type f -name 'test_*.cpp' -print0 2>/dev/null)
}

list_completion_words() {
  local include_test_targets="${1:-0}"
  local -A seen=()
  local w

  for w in "${SRC_TARGETS[@]}" "${MAIN_BASE_TARGETS[@]}" "${EXTRA_WORDS[@]}"; do
    [[ -n "${seen[$w]+x}" ]] && continue
    seen[$w]=1
    printf '%s\n' "$w"
  done

  if [[ "${include_test_targets}" == "1" ]]; then
    while IFS= read -r w; do
      [[ -n "${seen[$w]+x}" ]] || { seen["$w"]=1; printf '%s\n' "$w"; }
    done < <(list_test_targets)
  fi
}

cmd_complete() {
  local line="${COMP_LINE:-}"
  local point="${COMP_POINT:-${#line}}"
  local cur
  local arg_index
  local include_test_targets=0
  local -a words=()
  local candidate

  if (( point > ${#line} )); then
    point=${#line}
  fi

  line="${line:0:point}"
  read -r -a words <<< "$line"

  if [[ "$line" =~ [[:space:]]$ ]]; then
    cur=""
    arg_index=$((${#words[@]} - 1))
  else
    cur="${words[-1]:-}"
    arg_index=$((${#words[@]} - 2))
  fi

  if (( arg_index < 0 )); then
    arg_index=0
  fi

  # mkc accepts a single target argument; do not complete beyond that.
  if (( arg_index > 0 )); then
    return 0
  fi

  if [[ "$cur" == test* ]]; then
    include_test_targets=1
  fi

  while IFS= read -r candidate; do
    [[ "$candidate" == "$cur"* ]] || continue
    printf '%s\n' "$candidate"
  done < <(list_completion_words "$include_test_targets")
}

usage() {
  cat <<'EOF'
Usage:
  mkc
  mkc <target>
  mkc rules
  mkc targets
  mkc --help

Notes:
  - mkc runs exactly one target per invocation.
  - mkc runs make with -j$(nproc) by default.
  - Override jobs with MKC_JOBS=<N>.
  - Set MKC_SHOW_CMD=1 to print the dispatched make command.
  - With no target, mkc runs lib (library/core aggregate).
  - Use "mkc link" for the final linked binaries.
  - Use "mkc install" for the in-place finalize step after link.
  - Example: mkc lib, mkc link, mkc install, mkc runtime_hero, mkc test_network_analytics.
EOF
}

contains_word() {
  local needle="${1:-}"
  shift || true
  local item
  for item in "$@"; do
    if [[ "${item}" == "${needle}" ]]; then
      return 0
    fi
  done
  return 1
}

run_make() {
  local target="${1:-}"
  local make_dir="${MAIN_MAKE_DIR}"
  local cmd

  # Default to the canonical src library/core aggregate when no explicit target
  # is requested.
  if [[ -z "${target}" ]]; then
    target="lib"
  fi

  if contains_word "${target}" "${SRC_TARGETS[@]}"; then
    make_dir="${SRC_MAKE_DIR}"
  fi

  cmd=(make --no-print-directory -j"${MKC_JOBS}" -C "${make_dir}")
  [[ -n "${target}" ]] && cmd+=("${target}")

  if [[ "${MKC_SHOW_CMD:-0}" == "1" ]]; then
    printf 'mkc:'
    printf ' %q' "${cmd[@]}"
    printf '\n' >&2
  fi

  exec "${cmd[@]}"
}

if [[ "${1:-}" == "__complete" ]]; then
  cmd_complete
  exit 0
fi

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" || "${1:-}" == "help" ]]; then
  usage
  exit 0
fi

if (( $# > 1 )); then
  echo "mkc: ambiguous invocation: '$*'" >&2
  echo "mkc accepts one target only. Example: mkc tests" >&2
  exit 2
fi

case "${1:-}" in
  rules|production_rules|--rules)
    printf '%s\n' "${PRODUCTION_TARGETS[@]}"
    ;;
  targets|--targets)
    list_completion_words 1 | sort -u
    ;;
  "") run_make ;;
  *)
    run_make "$1"
    ;;
esac
