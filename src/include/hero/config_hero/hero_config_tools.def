#ifndef HERO_CONFIG_TOOL
#error "HERO_CONFIG_TOOL(NAME, DESCRIPTION, INPUT_SCHEMA_JSON, HANDLER) must be defined before including hero_config_tools.def"
#endif

// Config Hero tool registry. Keep tool metadata and handler bindings here so
// transport wrappers can derive tools/list/help/dispatch from one source.

HERO_CONFIG_TOOL("hero.config.status", "Runtime status and validation snapshot",
                 "{\"type\":\"object\",\"properties\":{},\"additionalProperties\":false}",
                 handle_tool_status)
HERO_CONFIG_TOOL("hero.config.schema", "Runtime key schema",
                 "{\"type\":\"object\",\"properties\":{},\"additionalProperties\":false}",
                 handle_tool_schema)
HERO_CONFIG_TOOL("hero.config.show", "Current key-value entries",
                 "{\"type\":\"object\",\"properties\":{},\"additionalProperties\":false}",
                 handle_tool_show)
HERO_CONFIG_TOOL("hero.config.get", "Get one key",
                 "{\"type\":\"object\",\"properties\":{\"key\":{\"type\":\"string\"}},\"required\":[\"key\"],\"additionalProperties\":false}",
                 handle_tool_get)
HERO_CONFIG_TOOL("hero.config.set", "Set one key",
                 "{\"type\":\"object\",\"properties\":{\"key\":{\"type\":\"string\"},\"value\":{\"type\":\"string\"}},\"required\":[\"key\",\"value\"],\"additionalProperties\":false}",
                 handle_tool_set)
HERO_CONFIG_TOOL("hero.config.default.read",
                 "Read one whole file under configured default_roots with an allowed extension, returning associated .man content when available",
                 "{\"type\":\"object\",\"properties\":{\"path\":{\"type\":\"string\"}},\"required\":[\"path\"],\"additionalProperties\":false}",
                 handle_tool_default_read)
HERO_CONFIG_TOOL("hero.config.default.list",
                 "List all allowed files under configured default_roots; include_man optionally inlines associated .man content",
                 "{\"type\":\"object\",\"properties\":{\"include_man\":{\"type\":\"boolean\"}},\"additionalProperties\":false}",
                 handle_tool_default_list)
HERO_CONFIG_TOOL("hero.config.default.create",
                 "Create one whole supported file under configured default_roots after decoder and file-specific validation",
                 "{\"type\":\"object\",\"properties\":{\"path\":{\"type\":\"string\"},\"content\":{\"type\":\"string\"}},\"required\":[\"path\",\"content\"],\"additionalProperties\":false}",
                 handle_tool_default_create)
HERO_CONFIG_TOOL("hero.config.default.replace",
                 "Replace one whole supported file under configured default_roots after decoder and file-specific validation",
                 "{\"type\":\"object\",\"properties\":{\"path\":{\"type\":\"string\"},\"content\":{\"type\":\"string\"},\"expected_sha256\":{\"type\":\"string\"}},\"required\":[\"path\",\"content\"],\"additionalProperties\":false}",
                 handle_tool_default_replace)
HERO_CONFIG_TOOL("hero.config.default.delete",
                 "Delete one whole file under configured default_roots after optional sha256 check",
                 "{\"type\":\"object\",\"properties\":{\"path\":{\"type\":\"string\"},\"expected_sha256\":{\"type\":\"string\"}},\"required\":[\"path\"],\"additionalProperties\":false}",
                 handle_tool_default_delete)
HERO_CONFIG_TOOL("hero.config.objective.read",
                 "Read one whole file under objective_root with an allowed extension, returning associated .man content when available",
                 "{\"type\":\"object\",\"properties\":{\"objective_root\":{\"type\":\"string\"},\"path\":{\"type\":\"string\"}},\"required\":[\"objective_root\",\"path\"],\"additionalProperties\":false}",
                 handle_tool_objective_read)
HERO_CONFIG_TOOL("hero.config.objective.list",
                 "List all allowed files under objective_root; include_man optionally inlines associated .man content",
                 "{\"type\":\"object\",\"properties\":{\"objective_root\":{\"type\":\"string\"},\"include_man\":{\"type\":\"boolean\"}},\"required\":[\"objective_root\"],\"additionalProperties\":false}",
                 handle_tool_objective_list)
HERO_CONFIG_TOOL("hero.config.objective.create",
                 "Create one whole file under objective_root with an allowed extension after decoder validation",
                 "{\"type\":\"object\",\"properties\":{\"objective_root\":{\"type\":\"string\"},\"path\":{\"type\":\"string\"},\"content\":{\"type\":\"string\"}},\"required\":[\"objective_root\",\"path\",\"content\"],\"additionalProperties\":false}",
                 handle_tool_objective_create)
HERO_CONFIG_TOOL("hero.config.objective.replace",
                 "Replace one whole file under objective_root with an allowed extension after decoder validation",
                 "{\"type\":\"object\",\"properties\":{\"objective_root\":{\"type\":\"string\"},\"path\":{\"type\":\"string\"},\"content\":{\"type\":\"string\"},\"expected_sha256\":{\"type\":\"string\"}},\"required\":[\"objective_root\",\"path\",\"content\"],\"additionalProperties\":false}",
                 handle_tool_objective_replace)
HERO_CONFIG_TOOL("hero.config.objective.delete",
                 "Delete one whole file under objective_root with an allowed extension after optional sha256 check",
                 "{\"type\":\"object\",\"properties\":{\"objective_root\":{\"type\":\"string\"},\"path\":{\"type\":\"string\"},\"expected_sha256\":{\"type\":\"string\"}},\"required\":[\"objective_root\",\"path\"],\"additionalProperties\":false}",
                 handle_tool_objective_delete)
HERO_CONFIG_TOOL("hero.config.optim.read",
                 "Read one whole file under the TSODAO hidden_root with an allowed extension, returning associated .man content when available",
                 "{\"type\":\"object\",\"properties\":{\"path\":{\"type\":\"string\"}},\"required\":[\"path\"],\"additionalProperties\":false}",
                 handle_tool_optim_read)
HERO_CONFIG_TOOL("hero.config.optim.list",
                 "List all allowed files under the TSODAO hidden_root; include_man optionally inlines associated .man content",
                 "{\"type\":\"object\",\"properties\":{\"include_man\":{\"type\":\"boolean\"}},\"additionalProperties\":false}",
                 handle_tool_optim_list)
HERO_CONFIG_TOOL("hero.config.optim.create",
                 "Create one whole file under the TSODAO hidden_root with an allowed extension after decoder validation and an encrypted pre-mutation checkpoint",
                 "{\"type\":\"object\",\"properties\":{\"path\":{\"type\":\"string\"},\"content\":{\"type\":\"string\"}},\"required\":[\"path\",\"content\"],\"additionalProperties\":false}",
                 handle_tool_optim_create)
HERO_CONFIG_TOOL("hero.config.optim.replace",
                 "Replace one whole file under the TSODAO hidden_root with an allowed extension after decoder validation and an encrypted pre-mutation checkpoint",
                 "{\"type\":\"object\",\"properties\":{\"path\":{\"type\":\"string\"},\"content\":{\"type\":\"string\"},\"expected_sha256\":{\"type\":\"string\"}},\"required\":[\"path\",\"content\"],\"additionalProperties\":false}",
                 handle_tool_optim_replace)
HERO_CONFIG_TOOL("hero.config.optim.delete",
                 "Delete one whole file under the TSODAO hidden_root with an allowed extension after optional sha256 check and an encrypted pre-mutation checkpoint",
                 "{\"type\":\"object\",\"properties\":{\"path\":{\"type\":\"string\"},\"expected_sha256\":{\"type\":\"string\"}},\"required\":[\"path\"],\"additionalProperties\":false}",
                 handle_tool_optim_delete)
HERO_CONFIG_TOOL("hero.config.optim.backups",
                 "List available encrypted TSODAO archive checkpoints for the optim hidden surface",
                 "{\"type\":\"object\",\"properties\":{},\"additionalProperties\":false}",
                 handle_tool_optim_backups)
HERO_CONFIG_TOOL("hero.config.optim.rollback",
                 "Rollback the optim hidden surface to an encrypted TSODAO archive checkpoint",
                 "{\"type\":\"object\",\"properties\":{\"backup\":{\"type\":\"string\"}},\"additionalProperties\":false}",
                 handle_tool_optim_rollback)
HERO_CONFIG_TOOL("hero.config.validate", "Validate runtime config",
                 "{\"type\":\"object\",\"properties\":{},\"additionalProperties\":false}",
                 handle_tool_validate)
HERO_CONFIG_TOOL("hero.config.diff", "Preview config changes before save",
                 "{\"type\":\"object\",\"properties\":{\"include_text\":{\"type\":\"boolean\"}},\"additionalProperties\":false}",
                 handle_tool_diff)
HERO_CONFIG_TOOL("hero.config.dry_run", "Alias of hero.config.diff",
                 "{\"type\":\"object\",\"properties\":{\"include_text\":{\"type\":\"boolean\"}},\"additionalProperties\":false}",
                 handle_tool_diff)
HERO_CONFIG_TOOL("hero.config.backups", "List available config backups",
                 "{\"type\":\"object\",\"properties\":{},\"additionalProperties\":false}",
                 handle_tool_backups)
HERO_CONFIG_TOOL("hero.config.rollback",
                 "Rollback config to a backup snapshot",
                 "{\"type\":\"object\",\"properties\":{\"backup\":{\"type\":\"string\"}},\"additionalProperties\":false}",
                 handle_tool_rollback)
HERO_CONFIG_TOOL("hero.config.save", "Save runtime config to disk",
                 "{\"type\":\"object\",\"properties\":{},\"additionalProperties\":false}",
                 handle_tool_save)
HERO_CONFIG_TOOL("hero.config.reload", "Reload runtime config from disk",
                 "{\"type\":\"object\",\"properties\":{},\"additionalProperties\":false}",
                 handle_tool_reload)
HERO_CONFIG_TOOL("hero.config.dev_nuke_reset",
                 "Developer reset: optionally snapshot runtime dump folders and Hero catalogs resolved from the saved global config, then clear them and reload Config Hero state",
                 "{\"type\":\"object\",\"properties\":{},\"additionalProperties\":false}",
                 handle_tool_dev_nuke_reset)
