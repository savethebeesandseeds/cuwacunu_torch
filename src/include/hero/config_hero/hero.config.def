/*
  hero.config.def
  X-macro registry for Config Hero runtime keys and future capability targets.

  Consumers may define:

    HERO_FUTURE_TARGET(ID, INCLUDE_PATH, SUMMARY)                             [optional]
    HERO_RUNTIME_KEY(KEY, TYPE, REQUIRED, DEFAULT_VALUE, RANGE, ALLOWED, SUMMARY) [optional]
*/

#ifndef HERO_FUTURE_TARGET
#define HERO_FUTURE_TARGET(ID, INCLUDE_PATH, SUMMARY)
#endif

#ifndef HERO_RUNTIME_KEY
#define HERO_RUNTIME_KEY(KEY, TYPE, REQUIRED, DEFAULT_VALUE, RANGE, ALLOWED, SUMMARY)
#endif

// Future capability targets (declared now, wiring later).
HERO_FUTURE_TARGET(TsiProbe, "tsiemene/tsi.probe",
                   "Read and reason over probe paths and probe payload flows")
HERO_FUTURE_TARGET(NetworkAnalytics, "piaabo/torch_compat/network_analytics",
                   "Interpret network analytics reports and anomalies")
HERO_FUTURE_TARGET(StatisticsSpace, "piaabo/math_compat/statistics_space",
                   "Use rolling/infinite statistics interpretation in fixes")

// Runtime key-value DSL surface.
HERO_RUNTIME_KEY("protocol_layer", "enum", 1, "STDIO", "one token", "STDIO,HTTPS/SSE",
                 "MCP protocol layer; HTTPS/SSE is intentionally not implemented yet")
HERO_RUNTIME_KEY("config_scope_root", "path", 1, "/cuwacunu/src/config", "existing directory",
                 "absolute_or_relative_path", "scope root for config-centric context loading")
HERO_RUNTIME_KEY("allow_local_read", "bool", 1, "true", "true|false", "true,false",
                 "allow local filesystem reads")
HERO_RUNTIME_KEY("allow_local_write", "bool", 1, "false", "true|false", "true,false",
                 "allow local filesystem writes")
HERO_RUNTIME_KEY("write_roots", "string", 1, "/tmp", "csv path list", "comma-separated paths",
                 "allowed write roots when allow_local_write=true")
HERO_RUNTIME_KEY("backup_enabled", "bool", 1, "true", "true|false", "true,false",
                 "enable rotating backups before each save")
HERO_RUNTIME_KEY("backup_dir", "path", 1, "/cuwacunu/.backups/hero.config",
                 "directory path", "absolute_or_relative_path",
                 "destination directory for rotating backups")
HERO_RUNTIME_KEY("backup_max_entries", "int", 1, "20", ">=1", "integer",
                 "maximum backup snapshots to retain")

#undef HERO_FUTURE_TARGET
#undef HERO_RUNTIME_KEY
