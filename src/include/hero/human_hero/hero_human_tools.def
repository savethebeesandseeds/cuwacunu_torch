#ifndef HERO_HUMAN_TOOL
#error "HERO_HUMAN_TOOL(NAME, DESCRIPTION, INPUT_SCHEMA_JSON, HANDLER) must be defined before including hero_human_tools.def"
#endif

HERO_HUMAN_TOOL(
    "hero.human.list_escalations",
    "List Super Hero loops currently paused in awaiting_human state",
    "{\"type\":\"object\",\"properties\":{\"limit\":{\"type\":\"integer\"},\"offset\":{\"type\":\"integer\"},\"newest_first\":{\"type\":\"boolean\"}},\"additionalProperties\":false}",
    handle_tool_list_escalations)
HERO_HUMAN_TOOL(
    "hero.human.list_reports",
    "List finished Super Hero loops whose summary reports still need human acknowledgment",
    "{\"type\":\"object\",\"properties\":{\"limit\":{\"type\":\"integer\"},\"offset\":{\"type\":\"integer\"},\"newest_first\":{\"type\":\"boolean\"}},\"additionalProperties\":false}",
    handle_tool_list_reports)
HERO_HUMAN_TOOL(
    "hero.human.get_escalation",
    "Fetch one pending human escalation by loop_id",
    "{\"type\":\"object\",\"properties\":{\"loop_id\":{\"type\":\"string\"}},\"required\":[\"loop_id\"],\"additionalProperties\":false}",
    handle_tool_get_escalation)
HERO_HUMAN_TOOL(
    "hero.human.get_report",
    "Fetch one pending finished-loop summary report by loop_id",
    "{\"type\":\"object\",\"properties\":{\"loop_id\":{\"type\":\"string\"}},\"required\":[\"loop_id\"],\"additionalProperties\":false}",
    handle_tool_get_report)
HERO_HUMAN_TOOL(
    "hero.human.ack_report",
    "Create a signed human acknowledgment for one finished-loop summary report",
    "{\"type\":\"object\",\"properties\":{\"loop_id\":{\"type\":\"string\"},\"note\":{\"type\":\"string\"}},\"required\":[\"loop_id\"],\"additionalProperties\":false}",
    handle_tool_ack_report)
HERO_HUMAN_TOOL(
    "hero.human.dismiss_report",
    "Create a signed human dismissal for one finished-loop summary report and clear it from the operator inbox",
    "{\"type\":\"object\",\"properties\":{\"loop_id\":{\"type\":\"string\"},\"note\":{\"type\":\"string\"}},\"required\":[\"loop_id\"],\"additionalProperties\":false}",
    handle_tool_dismiss_report)
HERO_HUMAN_TOOL(
    "hero.human.resolve_escalation",
    "Create a signed human resolution artifact for one pending escalation and apply it to Super Hero",
    "{\"type\":\"object\",\"properties\":{\"loop_id\":{\"type\":\"string\"},\"resolution_kind\":{\"type\":\"string\",\"enum\":[\"grant\",\"deny\",\"clarify\",\"stop\"]},\"reason\":{\"type\":\"string\"}},\"required\":[\"loop_id\",\"resolution_kind\",\"reason\"],\"additionalProperties\":false}",
    handle_tool_resolve_escalation)
