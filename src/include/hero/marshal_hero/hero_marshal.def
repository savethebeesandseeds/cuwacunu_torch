HERO_MARSHAL_TOOL(
    "hero.marshal.prepare.evaluate.budgeted",
    "Prepare bounded evaluate-target movement for one dispatchable Lattice "
    "target using an explicit driver policy from args_path.",
    R"({
      "type": "object",
      "properties": {
        "target_id": {
          "type": "string"
        },
        "mode": {
          "type": "string",
          "enum": ["plan", "dry_run", "execute"]
        },
        "args_path": {
          "type": "string"
        },
        "args_digest": {
          "type": "string"
        }
      },
      "required": ["target_id", "mode"],
      "additionalProperties": false
    })")

HERO_MARSHAL_TOOL(
    "hero.marshal.rollout",
    "Prepare or execute a bounded Kikijyeba historical replay rollout from a "
    "completed Runtime job: policy set plus Cajtucu paper execution profile "
    "becomes Runtime replay trajectory evidence. Accounting numeraire defaults "
    "from [ACCOUNTING].accounting_numeraire_node_id in .config. Runtime "
    "executes and writes reports; Marshal records the handoff. Rollout packet "
    "fields live in args_path.",
    R"({
      "type": "object",
      "required": ["mode", "args_path"],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["plan", "execute"]
        },
        "args_path": {
          "type": "string"
        },
        "args_digest": {
          "type": "string"
        },
        "include_machine_payload": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    })")

HERO_MARSHAL_TOOL(
    "hero.marshal.inspect.run.latest_chain",
    "Read-only Runtime latest-chain operator inspection.",
    R"({"type":"object","properties":{"runtime_root":{"type":"string"},"config_path":{"type":"string"},"job_ids":{"type":"array","items":{"type":"string"}},"target_ids":{"type":"array","items":{"type":"string"}},"include_machine_payload":{"type":"boolean"}},"additionalProperties":false})")

