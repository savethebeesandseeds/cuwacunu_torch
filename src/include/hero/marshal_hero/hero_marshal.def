/*
  Marshal Hero public tool registry.

  Consumers may define:
    HERO_MARSHAL_TOOL(NAME, DESCRIPTION, INPUT_SCHEMA_JSON)
*/

#ifndef HERO_MARSHAL_TOOL
#define HERO_MARSHAL_TOOL(NAME, DESCRIPTION, INPUT_SCHEMA_JSON)
#endif

HERO_MARSHAL_TOOL(
    "hero.marshal.status",
    "Summarize Marshal receipts, policy surface, and advice availability.",
    R"({"type":"object","properties":{"receipt_root":{"type":"string"},"limit":{"type":"integer"},"receipts":{"type":"array","items":{"type":"object"}},"runtime_policy":{"type":"object"},"lattice_advice_surface_available":{"type":"boolean"}},"additionalProperties":false})")

HERO_MARSHAL_TOOL(
    "hero.marshal.reach_lattice_target",
    "High-level Marshal operator tool for moving one lattice target toward "
    "readiness by preparing a concrete Runtime handoff, optionally dry-running "
    "it, and returning the next safe action without executing by default.",
    R"({"type":"object","properties":{"target_id":{"type":"string"},"config_path":{"type":"string"},"runtime_root":{"type":"string"},"requested_mode":{"type":"string"},"drive_mode":{"type":"string"},"driver_policy":{"type":"object"},"resume_ledger":{"type":"object"},"source_lattice_timestamp":{"type":"string"},"max_waves":{"type":"integer"},"recommendation_attempt_count":{"type":"integer"},"context":{"type":"object"},"protocol_contract_fingerprint":{"type":"string"},"graph_order_fingerprint":{"type":"string"},"source_cursor_token":{"type":"string"},"vicreg_assembly_fingerprint":{"type":"string"},"mdn_assembly_fingerprint":{"type":"string"},"materialize_plan_inputs":{"type":"boolean"},"include_runtime_dry_run":{"type":"boolean"},"include_machine_payload":{"type":"boolean"},"runtime_policy":{"type":"object"},"runtime_wave":{"type":"object"},"timeout_seconds":{"type":"integer"}},"required":["target_id","drive_mode"],"additionalProperties":false})")

HERO_MARSHAL_TOOL(
    "hero.marshal.evaluate",
    "High-level Marshal operator evaluator. Deterministic subjects run, "
    "target, protocol, spawn, and component explain Runtime and Lattice "
    "evidence without execution, proof claims, model selection, or checkpoint "
    "selection.",
    R"({"type":"object","properties":{"subject":{"type":"string","enum":["run","target","protocol","spawn","component"]},"mode":{"type":"string"},"identity_mode":{"type":"string"},"runtime_root":{"type":"string"},"config_path":{"type":"string"},"target_id":{"type":"string"},"job_id":{"type":"string"},"job_ids":{"type":"array","items":{"type":"string"}},"target_ids":{"type":"array","items":{"type":"string"}},"baseline_job_id":{"type":"string"},"candidate_job_id":{"type":"string"},"component_family_id":{"type":"string"},"component":{"type":"string"},"spawn_id":{"type":"string"},"component_spawn_id":{"type":"string"},"component_spawn_registry_id":{"type":"string"},"component_spawn_label":{"type":"string"},"component_spawn_fingerprint":{"type":"string"},"include_machine_payload":{"type":"boolean"},"protocol_contract_fingerprint":{"type":"string"},"graph_order_fingerprint":{"type":"string"},"source_cursor_token":{"type":"string"},"vicreg_assembly_fingerprint":{"type":"string"},"mdn_assembly_fingerprint":{"type":"string"}},"required":["subject"],"additionalProperties":false})")

#undef HERO_MARSHAL_TOOL
