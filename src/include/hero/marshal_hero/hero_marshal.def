/*
  Marshal Hero public tool registry.

  Consumers may define:
    HERO_MARSHAL_TOOL(NAME, DESCRIPTION, INPUT_SCHEMA_JSON)
*/

#ifndef HERO_MARSHAL_TOOL
#define HERO_MARSHAL_TOOL(NAME, DESCRIPTION, INPUT_SCHEMA_JSON)
#endif

HERO_MARSHAL_TOOL(
    "hero.marshal.status",
    "Read-only Marshal health and authority-boundary summary: recent receipts, "
    "policy/advice visibility, refusal state, caller-supplied test surfaces, "
    "and explicit non-executor/non-proof flags.",
    R"({"type":"object","properties":{"receipt_root":{"type":"string"},"limit":{"type":"integer"},"receipts":{"type":"array","items":{"type":"object"}},"runtime_policy":{"type":"object"},"lattice_advice_surface_available":{"type":"boolean"}},"additionalProperties":false})")

HERO_MARSHAL_TOOL(
    "hero.marshal.prepare",
    "Prepare finite movement for one dispatchable Lattice target. Train/"
    "evaluate are the current target-movement path; replay uses rollout, "
    "artifact-readiness routes to inspect, and policy-training is reserved "
    "until a concrete Runtime contract exists.",
    R"({"type":"object","properties":{"target_id":{"type":"string"},"intent":{"type":"string"},"config_path":{"type":"string"},"runtime_root":{"type":"string"},"requested_mode":{"type":"string","enum":["plan","dry_run","execute"]},"drive_mode":{"type":"string","enum":["one_step","budgeted"]},"driver_policy":{"type":"object"},"resume_ledger":{"type":"object"},"source_lattice_timestamp":{"type":"string"},"max_waves":{"type":"integer"},"recommendation_attempt_count":{"type":"integer"},"context":{"type":"object"},"protocol_contract_fingerprint":{"type":"string"},"graph_order_fingerprint":{"type":"string"},"source_cursor_token":{"type":"string"},"vicreg_assembly_fingerprint":{"type":"string"},"mdn_assembly_fingerprint":{"type":"string"},"materialize_plan_inputs":{"type":"boolean"},"include_runtime_dry_run":{"type":"boolean"},"include_machine_payload":{"type":"boolean"},"runtime_policy":{"type":"object"},"runtime_wave":{"type":"object"},"timeout_seconds":{"type":"integer"},"ledger_created_at_utc":{"type":"string"},"ledger_nonce":{"type":"string"}},"required":["target_id"],"additionalProperties":false})")

HERO_MARSHAL_TOOL(
    "hero.marshal.rollout",
    "Prepare or execute a bounded Kikijyeba historical replay rollout from a "
    "completed Runtime job: policy set plus Cajtucu paper execution profile "
    "becomes Runtime replay trajectory evidence. Runtime executes and writes "
    "reports; Marshal records the handoff.",
    R"({"type":"object","properties":{"rollout_id":{"type":"string"},"rollout_attempt_id":{"type":"string"},"idempotency_key":{"type":"string"},"experiment_id":{"type":"string"},"config_path":{"type":"string"},"runtime_job_dir":{"type":"string"},"replay_batch_index_path":{"type":"string"},"runtime_exec_path":{"type":"string"},"report_path":{"type":"string"},"requested_mode":{"type":"string","enum":["plan","execute"]},"environment_mode":{"type":"string"},"environment_assembly_id":{"type":"string"},"graph_order_fingerprint":{"type":"string"},"asset_universe_digest":{"type":"string"},"base_reserve_node_id":{"type":"string"},"risky_node_ids":{"type":"array","items":{"type":"string"}},"policy_set":{"type":"array","items":{"type":"string"}},"max_steps":{"type":"integer"},"max_parallel_jobs":{"type":"integer"},"execution_profile":{"type":"object","properties":{"execution_backend_id":{"type":"string"},"cost_model_id":{"type":"string"},"allow_synthetic_direct_edges":{"type":"boolean"},"synthetic_edge_research_reason":{"type":"string"},"linear_transaction_cost_rate":{"type":"number"},"allow_partial_fills":{"type":"boolean"},"allow_negative_base_reserve":{"type":"boolean"},"equity_mismatch_tolerance":{"type":"number"},"equity_mismatch_fail_tolerance":{"type":"number"},"live_execution_allowed":{"type":"boolean"}},"additionalProperties":false},"timeout_seconds":{"type":"integer"},"require_existing_runtime_job_dir":{"type":"boolean"},"require_completed_runtime_job":{"type":"boolean"},"require_replay_artifacts":{"type":"boolean"},"include_machine_payload":{"type":"boolean"}},"required":["rollout_id","rollout_attempt_id","idempotency_key","runtime_job_dir","replay_batch_index_path","requested_mode","graph_order_fingerprint","asset_universe_digest","base_reserve_node_id","risky_node_ids","policy_set","max_steps"],"additionalProperties":false})")

HERO_MARSHAL_TOOL(
    "hero.marshal.inspect",
    "Read-only evidence inspection. Subjects run, target, protocol, spawn, "
    "component, and facts explain Runtime/Lattice/Marshal state without "
    "execution, proof claims, checkpoint selection, policy selection, or "
    "writes.",
    R"({"type":"object","properties":{"subject":{"type":"string","enum":["run","target","protocol","spawn","component","facts"]},"mode":{"type":"string"},"identity_mode":{"type":"string","enum":["report","strict"]},"runtime_root":{"type":"string"},"config_path":{"type":"string"},"target_id":{"type":"string"},"job_id":{"type":"string"},"job_ids":{"type":"array","items":{"type":"string"}},"target_ids":{"type":"array","items":{"type":"string"}},"baseline_job_id":{"type":"string"},"candidate_job_id":{"type":"string"},"component_family_id":{"type":"string"},"spawn_id":{"type":"string"},"component_spawn_id":{"type":"string"},"component_spawn_registry_id":{"type":"string"},"component_spawn_label":{"type":"string"},"component_spawn_fingerprint":{"type":"string"},"fact_family_id":{"type":"string"},"limit":{"type":"integer"},"include_facts":{"type":"boolean"},"include_lineage":{"type":"boolean"},"include_preview":{"type":"boolean"},"fact_digest":{"type":"string"},"fact_digest_prefix":{"type":"string"},"fact_index":{"type":"integer"},"include_machine_payload":{"type":"boolean"},"protocol_contract_fingerprint":{"type":"string"},"graph_order_fingerprint":{"type":"string"},"source_cursor_token":{"type":"string"},"vicreg_assembly_fingerprint":{"type":"string"},"mdn_assembly_fingerprint":{"type":"string"}},"required":["subject"],"additionalProperties":false})")

#undef HERO_MARSHAL_TOOL
