/*
  Marshal Hero public tool registry.

  Consumers may define:
    HERO_MARSHAL_TOOL(NAME, DESCRIPTION, INPUT_SCHEMA_JSON)
*/

#ifndef HERO_MARSHAL_TOOL
#define HERO_MARSHAL_TOOL(NAME, DESCRIPTION, INPUT_SCHEMA_JSON)
#endif

HERO_MARSHAL_TOOL(
    "hero.marshal.status",
    "Summarize Marshal receipts, policy surface, and advice availability.",
    R"({"type":"object","properties":{"receipt_root":{"type":"string"},"limit":{"type":"integer"},"receipts":{"type":"array","items":{"type":"object"}},"runtime_policy":{"type":"object"},"lattice_advice_surface_available":{"type":"boolean"}},"additionalProperties":false})")

HERO_MARSHAL_TOOL(
    "hero.marshal.prepare",
    "Prepare a bounded Runtime handoff for a lattice target. The default "
    "intent is train, but Marshal still does not execute or prove target "
    "satisfaction.",
    R"({"type":"object","properties":{"target_id":{"type":"string"},"lattice_target":{"type":"string"},"intent":{"type":"string"},"config_path":{"type":"string"},"runtime_root":{"type":"string"},"requested_mode":{"type":"string"},"drive_mode":{"type":"string"},"driver_policy":{"type":"object"},"resume_ledger":{"type":"object"},"source_lattice_timestamp":{"type":"string"},"max_waves":{"type":"integer"},"recommendation_attempt_count":{"type":"integer"},"context":{"type":"object"},"protocol_contract_fingerprint":{"type":"string"},"graph_order_fingerprint":{"type":"string"},"source_cursor_token":{"type":"string"},"vicreg_assembly_fingerprint":{"type":"string"},"mdn_assembly_fingerprint":{"type":"string"},"materialize_plan_inputs":{"type":"boolean"},"include_runtime_dry_run":{"type":"boolean"},"include_machine_payload":{"type":"boolean"},"runtime_policy":{"type":"object"},"runtime_wave":{"type":"object"},"timeout_seconds":{"type":"integer"},"rollout_id":{"type":"string"},"experiment_id":{"type":"string"},"runtime_job_dir":{"type":"string"},"runtime_exec_path":{"type":"string"},"report_path":{"type":"string"},"environment_mode":{"type":"string"},"environment_assembly_id":{"type":"string"},"base_reserve_node_id":{"type":"string"},"risky_node_ids":{"type":"array","items":{"type":"string"}},"policy_set":{"type":"array","items":{"type":"string"}},"max_steps":{"type":"integer"},"max_parallel_jobs":{"type":"integer"},"execution_profile":{"type":"object"},"require_existing_runtime_job_dir":{"type":"boolean"},"require_completed_runtime_job":{"type":"boolean"},"require_replay_artifacts":{"type":"boolean"},"prepare_only":{"type":"boolean"}},"additionalProperties":false})")

HERO_MARSHAL_TOOL(
    "hero.marshal.inspect",
    "Read-only Marshal inspection tool. Subjects run, target, protocol, "
    "spawn, component, and facts explain Runtime/Lattice evidence without "
    "execution, proof claims, checkpoint selection, or writes.",
    R"({"type":"object","properties":{"subject":{"type":"string","enum":["run","target","protocol","spawn","component","facts"]},"mode":{"type":"string"},"identity_mode":{"type":"string"},"runtime_root":{"type":"string"},"config_path":{"type":"string"},"target_id":{"type":"string"},"job_id":{"type":"string"},"job_ids":{"type":"array","items":{"type":"string"}},"target_ids":{"type":"array","items":{"type":"string"}},"baseline_job_id":{"type":"string"},"candidate_job_id":{"type":"string"},"component_family_id":{"type":"string"},"component":{"type":"string"},"spawn_id":{"type":"string"},"component_spawn_id":{"type":"string"},"component_spawn_registry_id":{"type":"string"},"component_spawn_label":{"type":"string"},"component_spawn_fingerprint":{"type":"string"},"fact_family":{"type":"string"},"family":{"type":"string"},"limit":{"type":"integer"},"include_facts":{"type":"boolean"},"include_lineage":{"type":"boolean"},"include_preview":{"type":"boolean"},"digest":{"type":"string"},"fact_digest":{"type":"string"},"digest_prefix":{"type":"string"},"fact_index":{"type":"integer"},"index":{"type":"integer"},"include_machine_payload":{"type":"boolean"},"protocol_contract_fingerprint":{"type":"string"},"graph_order_fingerprint":{"type":"string"},"source_cursor_token":{"type":"string"},"vicreg_assembly_fingerprint":{"type":"string"},"mdn_assembly_fingerprint":{"type":"string"}},"required":["subject"],"additionalProperties":false})")

#undef HERO_MARSHAL_TOOL
