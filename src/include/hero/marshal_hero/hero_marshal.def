/*
  Marshal Hero public tool registry.

  Consumers may define:
    HERO_MARSHAL_TOOL(NAME, DESCRIPTION, INPUT_SCHEMA_JSON)
*/

#ifndef HERO_MARSHAL_TOOL
#define HERO_MARSHAL_TOOL(NAME, DESCRIPTION, INPUT_SCHEMA_JSON)
#endif

HERO_MARSHAL_TOOL(
    "hero.marshal.status",
    "Read-only Marshal health and authority-boundary summary: recent receipts, "
    "policy/advice visibility, refusal state, caller-supplied test surfaces, "
    "and explicit non-executor/non-proof flags.",
    R"({"type":"object","properties":{},"additionalProperties":false})")

HERO_MARSHAL_TOOL(
    "hero.marshal.prepare.train",
    "Prepare train-target movement for one dispatchable Lattice target using "
    "a Marshal prepare profile. Replay uses rollout, artifact-readiness "
    "routes to inspect, and policy-training is reserved until a concrete "
    "Runtime contract exists. Marshal derives Lattice/Runtime evidence at "
    "call time.",
    R"({
      "type": "object",
      "properties": {
        "target_id": {
          "type": "string"
        },
        "mode": {
          "type": "string",
          "enum": ["plan", "dry_run", "execute"]
        },
        "profile": {
          "type": "string"
        },
        "include_machine_payload": {
          "type": "boolean"
        }
      },
      "required": ["target_id", "mode"],
      "additionalProperties": false
    })")

HERO_MARSHAL_TOOL(
    "hero.marshal.prepare.evaluate",
    "Prepare evaluate-target movement for one dispatchable Lattice target "
    "using a Marshal prepare profile. Replay uses rollout and "
    "artifact-readiness routes to inspect. Marshal derives Lattice/Runtime "
    "evidence at call time.",
    R"({
      "type": "object",
      "properties": {
        "target_id": {
          "type": "string"
        },
        "mode": {
          "type": "string",
          "enum": ["plan", "dry_run", "execute"]
        },
        "profile": {
          "type": "string"
        },
        "include_machine_payload": {
          "type": "boolean"
        }
      },
      "required": ["target_id", "mode"],
      "additionalProperties": false
    })")

HERO_MARSHAL_TOOL(
    "hero.marshal.rollout",
    "Prepare or execute a bounded Kikijyeba historical replay rollout from a "
    "completed Runtime job using a Marshal rollout profile. Runtime executes "
    "and writes reports; Marshal records the handoff.",
    R"({
      "type": "object",
      "required": ["mode", "runtime_job_dir", "rollout_id", "rollout_attempt_id", "target_node_ids"],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["plan", "execute"]
        },
        "runtime_job_dir": {
          "type": "string"
        },
        "rollout_id": {
          "type": "string"
        },
        "rollout_attempt_id": {
          "type": "string"
        },
        "target_node_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "profile": {
          "type": "string"
        },
        "include_machine_payload": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    })")

HERO_MARSHAL_TOOL(
    "hero.marshal.paper_online.session_handoff",
    "Prepare a bounded paper-online session handoff from existing readiness "
    "evidence and optional session-admission evidence. mode=plan constructs "
    "the Environment-compatible admission/session payloads without tool calls; "
    "mode=dry_run performs safe Environment admission check and session "
    "validate only. Marshal writes a handoff receipt but never issues "
    "admission, runs the session, routes broker orders, or proves Lattice "
    "targets.",
    R"({
      "type": "object",
      "required": ["mode"],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["plan", "dry_run"]
        },
        "handoff_request": {
          "type": "object"
        },
        "handoff_request_path": {
          "type": "string"
        },
        "include_machine_payload": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    })")

