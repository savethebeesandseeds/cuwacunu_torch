/*
  Marshal Hero public tool registry.

  Consumers may define:
    HERO_MARSHAL_TOOL(NAME, DESCRIPTION, INPUT_SCHEMA_JSON)
*/

#ifndef HERO_MARSHAL_TOOL
#define HERO_MARSHAL_TOOL(NAME, DESCRIPTION, INPUT_SCHEMA_JSON)
#endif

HERO_MARSHAL_TOOL(
    "hero.marshal.status",
    "Read-only Marshal health and authority-boundary summary: recent receipts, "
    "policy/advice visibility, refusal state, caller-supplied test surfaces, "
    "and explicit non-executor/non-proof flags.",
    R"({"type":"object","properties":{},"additionalProperties":false})")

HERO_MARSHAL_TOOL(
    "hero.marshal.prepare.train.one_step",
    "Prepare one finite train-target movement for one dispatchable Lattice "
    "target. This is the single-step target-movement path; replay uses "
    "rollout, artifact-readiness routes to inspect, and policy-training is "
    "reserved until a concrete Runtime contract exists. Target-specific "
    "payload fields live in args_path.",
    R"({
      "type": "object",
      "properties": {
        "target_id": {
          "type": "string"
        },
        "mode": {
          "type": "string",
          "enum": ["plan", "dry_run", "execute"]
        },
        "args_path": {
          "type": "string"
        },
        "args_digest": {
          "type": "string"
        }
      },
      "required": ["target_id", "mode"],
      "additionalProperties": false
    })")

HERO_MARSHAL_TOOL(
    "hero.marshal.prepare.train.budgeted",
    "Prepare bounded train-target movement for one dispatchable Lattice "
    "target using an explicit driver policy from args_path.",
    R"({
      "type": "object",
      "properties": {
        "target_id": {
          "type": "string"
        },
        "mode": {
          "type": "string",
          "enum": ["plan", "dry_run", "execute"]
        },
        "args_path": {
          "type": "string"
        },
        "args_digest": {
          "type": "string"
        }
      },
      "required": ["target_id", "mode"],
      "additionalProperties": false
    })")

HERO_MARSHAL_TOOL(
    "hero.marshal.prepare.evaluate.one_step",
    "Prepare one finite evaluate-target movement for one dispatchable Lattice "
    "target. This is the single-step target-movement path; replay uses "
    "rollout and artifact-readiness routes to inspect. Target-specific "
    "payload fields live in args_path.",
    R"({
