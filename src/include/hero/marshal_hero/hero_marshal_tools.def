#ifndef HERO_MARSHAL_TOOL
#error "HERO_MARSHAL_TOOL(NAME, DESCRIPTION, INPUT_SCHEMA_JSON, HANDLER) must be defined before including hero_marshal_tools.def"
#endif

HERO_MARSHAL_TOOL(
    "hero.marshal.start_session",
    "Start a detached Marshal Hero session from the selected marshal.objective.dsl; optional marshal_codex_model and marshal_codex_reasoning_effort override the defaults for this session only while Runtime Hero remains the campaign executor",
    "{\"type\":\"object\",\"properties\":{\"marshal_objective_dsl_path\":{\"type\":\"string\"},\"marshal_codex_model\":{\"type\":\"string\"},\"marshal_codex_reasoning_effort\":{\"type\":\"string\"}},\"additionalProperties\":false}",
    handle_tool_start_session)
HERO_MARSHAL_TOOL(
    "hero.marshal.list_sessions",
    "List known Marshal Hero sessions keyed by marshal cursor",
    "{\"type\":\"object\",\"properties\":{\"lifecycle\":{\"type\":\"string\"},\"limit\":{\"type\":\"integer\"},\"offset\":{\"type\":\"integer\"},\"newest_first\":{\"type\":\"boolean\"}},\"additionalProperties\":false}",
    handle_tool_list_sessions)
HERO_MARSHAL_TOOL(
    "hero.marshal.get_session",
    "Fetch one Marshal Hero session by marshal cursor",
    "{\"type\":\"object\",\"properties\":{\"marshal_session_id\":{\"type\":\"string\"}},\"required\":[\"marshal_session_id\"],\"additionalProperties\":false}",
    handle_tool_get_session)
HERO_MARSHAL_TOOL(
    "hero.marshal.reconcile_session",
    "Reconcile one Marshal Hero session after sudden interruption or stale runtime state, parking it review-ready with recovery context when needed",
    "{\"type\":\"object\",\"properties\":{\"marshal_session_id\":{\"type\":\"string\"}},\"required\":[\"marshal_session_id\"],\"additionalProperties\":false}",
    handle_tool_reconcile_session)
HERO_MARSHAL_TOOL(
    "hero.marshal.pause_session",
    "Pause one Marshal Hero session and optionally force-stop its active Runtime campaign",
    "{\"type\":\"object\",\"properties\":{\"marshal_session_id\":{\"type\":\"string\"},\"force\":{\"type\":\"boolean\"}},\"required\":[\"marshal_session_id\"],\"additionalProperties\":false}",
    handle_tool_pause_session)
HERO_MARSHAL_TOOL(
    "hero.marshal.resume_session",
    "Resume one live Marshal Hero session through operator pause release, clarification answer, or governance resolution",
    "{\"type\":\"object\",\"properties\":{\"marshal_session_id\":{\"type\":\"string\"},\"governance_resolution_path\":{\"type\":\"string\"},\"governance_resolution_sig_path\":{\"type\":\"string\"},\"clarification_answer_path\":{\"type\":\"string\"}},\"required\":[\"marshal_session_id\"],\"additionalProperties\":false}",
    handle_tool_resume_session)
HERO_MARSHAL_TOOL(
    "hero.marshal.message_session",
    "Deliver one operator message into a live Marshal Hero session; the response returns a stable message_id plus queued|delivered|failed delivery state, review-ready sessions wake immediately, and other live sessions now wake the runner for direct thread delivery when continuity is available, falling back to queued safe-point delivery otherwise",
    "{\"type\":\"object\",\"properties\":{\"marshal_session_id\":{\"type\":\"string\"},\"message\":{\"type\":\"string\"}},\"required\":[\"marshal_session_id\",\"message\"],\"additionalProperties\":false}",
    handle_tool_message_session)
HERO_MARSHAL_TOOL(
    "hero.marshal.archive_session",
    "Archive one review-ready Marshal Hero session, marking it terminal so its objective can be launched again without overloading summary acknowledgment",
    "{\"type\":\"object\",\"properties\":{\"marshal_session_id\":{\"type\":\"string\"}},\"required\":[\"marshal_session_id\"],\"additionalProperties\":false}",
    handle_tool_archive_session)
HERO_MARSHAL_TOOL(
    "hero.marshal.terminate_session",
    "Terminate one Marshal Hero session and optionally force-stop its active Runtime campaign",
    "{\"type\":\"object\",\"properties\":{\"marshal_session_id\":{\"type\":\"string\"},\"force\":{\"type\":\"boolean\"}},\"required\":[\"marshal_session_id\"],\"additionalProperties\":false}",
    handle_tool_terminate_session)
