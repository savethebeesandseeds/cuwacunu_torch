#ifndef HERO_HASHIMYEI_TOOL
#error "HERO_HASHIMYEI_TOOL(NAME, DESCRIPTION, INPUT_SCHEMA_JSON, HANDLER) must be defined before including hero_hashimyei_tools.def"
#endif

HERO_HASHIMYEI_TOOL("hero.hashimyei.list", "List component identities in the Hashimyei catalog; this is the component-discovery layer that complements Lattice fact queries", "{\"type\":\"object\",\"properties\":{\"include_non_hashimyei\":{\"type\":\"boolean\"},\"canonical_path_prefix\":{\"type\":\"string\"},\"limit\":{\"type\":\"integer\"},\"offset\":{\"type\":\"integer\"}},\"additionalProperties\":false}", handle_tool_list)
HERO_HASHIMYEI_TOOL("hero.hashimyei.get_component_manifest", "Fetch the current manifest/state for a component identity by canonical_path or hashimyei", "{\"type\":\"object\",\"properties\":{\"canonical_path\":{\"type\":\"string\"},\"hashimyei\":{\"type\":\"string\"}},\"anyOf\":[{\"required\":[\"canonical_path\"]},{\"required\":[\"hashimyei\"]}],\"additionalProperties\":false}", handle_tool_get_component_manifest)
HERO_HASHIMYEI_TOOL("hero.hashimyei.get_founding_dsl", "Fetch founding component DSL for a component identity by canonical_path or hashimyei", "{\"type\":\"object\",\"properties\":{\"canonical_path\":{\"type\":\"string\"},\"hashimyei\":{\"type\":\"string\"},\"include_content\":{\"type\":\"boolean\"}},\"anyOf\":[{\"required\":[\"canonical_path\"]},{\"required\":[\"hashimyei\"]}],\"additionalProperties\":false}", handle_tool_get_founding_dsl)
HERO_HASHIMYEI_TOOL("hero.hashimyei.update_rank", "Persist a deterministic contract-scoped family rank ordering and mirror it into the lattice ranking overlay; rank zero is the best member", "{\"type\":\"object\",\"properties\":{\"family\":{\"type\":\"string\"},\"contract_hash\":{\"type\":\"string\"},\"ordered_hashimyeis\":{\"type\":\"array\",\"items\":{\"type\":\"string\"}},\"source_view_kind\":{\"type\":\"string\"},\"source_view_transport_sha256\":{\"type\":\"string\"}},\"required\":[\"family\",\"contract_hash\",\"ordered_hashimyeis\"],\"additionalProperties\":false}", handle_tool_update_rank)
HERO_HASHIMYEI_TOOL("hero.hashimyei.reset_catalog", "Rebuild the Hashimyei component catalog; set reingest=true to rescan component manifests from store_root", "{\"type\":\"object\",\"properties\":{\"reingest\":{\"type\":\"boolean\"}},\"additionalProperties\":false}", handle_tool_reset_catalog)
