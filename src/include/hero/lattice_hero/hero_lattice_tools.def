#ifndef HERO_LATTICE_TOOL
#error "HERO_LATTICE_TOOL(NAME, DESCRIPTION, INPUT_SCHEMA_JSON, HANDLER) must be defined before including hero_lattice_tools.def"
#endif

HERO_LATTICE_TOOL("hero.lattice.list_facts", "List available assembled fact bundles. Without canonical_path it lists known component canonical paths with latest available wave context; with canonical_path it lists available wave contexts for that component", "{\"type\":\"object\",\"properties\":{\"canonical_path\":{\"type\":\"string\"},\"limit\":{\"type\":\"integer\"},\"offset\":{\"type\":\"integer\"}},\"additionalProperties\":false}", handle_tool_list_facts)
HERO_LATTICE_TOOL("hero.lattice.get_fact", "Fetch the assembled complete fact bundle for a component canonical_path. Defaults to the latest available bundle; provide wave_cursor as <run>.<epoch>.<batch> to select an exact context", "{\"type\":\"object\",\"properties\":{\"canonical_path\":{\"type\":\"string\"},\"wave_cursor\":{\"type\":\"string\"}},\"required\":[\"canonical_path\"],\"additionalProperties\":false}", handle_tool_get_fact)
HERO_LATTICE_TOOL("hero.lattice.list_views", "List derived view kinds available from the lattice query engine without materializing their transport payloads", "{\"type\":\"object\",\"properties\":{},\"additionalProperties\":false}", handle_tool_list_views)
HERO_LATTICE_TOOL("hero.lattice.get_view", "Fetch a derived view transport. entropic_capacity_comparison requires wave_cursor; family_evaluation_report requires canonical_path plus contract_hash and defaults to the latest coherent bundle unless wave_cursor is provided", "{\"type\":\"object\",\"properties\":{\"view_kind\":{\"type\":\"string\"},\"canonical_path\":{\"type\":\"string\"},\"wave_cursor\":{\"type\":\"string\"},\"contract_hash\":{\"type\":\"string\"}},\"required\":[\"view_kind\"],\"additionalProperties\":false}", handle_tool_get_view)
HERO_LATTICE_TOOL("hero.lattice.refresh", "Rebuild the lattice fact catalog. Set reingest=true to rescan emitted runtime .lls facts from store_root before querying", "{\"type\":\"object\",\"properties\":{\"reingest\":{\"type\":\"boolean\"}},\"additionalProperties\":false}", handle_tool_refresh)
