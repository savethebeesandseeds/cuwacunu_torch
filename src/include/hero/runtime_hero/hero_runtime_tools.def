#ifndef HERO_RUNTIME_TOOL
#error "HERO_RUNTIME_TOOL(NAME, DESCRIPTION, INPUT_SCHEMA_JSON, HANDLER) must be defined before including hero_runtime_tools.def"
#endif

// Runtime Hero tool registry. Keep the metadata and handler binding together so
// tools/list, one-shot CLI, and MCP dispatch share one source of truth.
HERO_RUNTIME_TOOL("hero.runtime.launch_default_board", "Launch the default board worker as a detached supervised job keyed by job_cursor", "{\"type\":\"object\",\"properties\":{\"binding\":{\"type\":\"string\"},\"config_folder\":{\"type\":\"string\"},\"reset_runtime_state\":{\"type\":\"boolean\"}},\"additionalProperties\":false}", handle_tool_launch_default_board)
HERO_RUNTIME_TOOL("hero.runtime.list_jobs", "List known runtime jobs keyed by job_cursor", "{\"type\":\"object\",\"properties\":{\"state\":{\"type\":\"string\"},\"limit\":{\"type\":\"integer\"},\"offset\":{\"type\":\"integer\"},\"newest_first\":{\"type\":\"boolean\"}},\"additionalProperties\":false}", handle_tool_list_jobs)
HERO_RUNTIME_TOOL("hero.runtime.get_job", "Fetch one runtime job by job_cursor", "{\"type\":\"object\",\"properties\":{\"job_cursor\":{\"type\":\"string\"}},\"required\":[\"job_cursor\"],\"additionalProperties\":false}", handle_tool_get_job)
HERO_RUNTIME_TOOL("hero.runtime.stop_job", "Signal one runtime job by job_cursor", "{\"type\":\"object\",\"properties\":{\"job_cursor\":{\"type\":\"string\"},\"force\":{\"type\":\"boolean\"}},\"required\":[\"job_cursor\"],\"additionalProperties\":false}", handle_tool_stop_job)
HERO_RUNTIME_TOOL("hero.runtime.tail_log", "Read the tail of one runtime job log by job_cursor", "{\"type\":\"object\",\"properties\":{\"job_cursor\":{\"type\":\"string\"},\"stream\":{\"type\":\"string\"},\"lines\":{\"type\":\"integer\"}},\"required\":[\"job_cursor\"],\"additionalProperties\":false}", handle_tool_tail_log)
HERO_RUNTIME_TOOL("hero.runtime.reconcile", "Refresh runtime job manifests from current process liveness and mark stale active jobs", "{\"type\":\"object\",\"properties\":{},\"additionalProperties\":false}", handle_tool_reconcile)
