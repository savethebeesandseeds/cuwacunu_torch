#ifndef TSI_PATH_DIRECTIVE
#error                                                                         \
    "TSI_PATH_DIRECTIVE(ID, TOKEN, SUMMARY) must be defined before including tsi.paths.def"
#endif

#ifndef TSI_PATH_METHOD
#define TSI_PATH_METHOD(ID, TOKEN, SUMMARY)
#endif

#ifndef TSI_PATH_COMPONENT
#define TSI_PATH_COMPONENT(TYPE_ID, CANONICAL, DOMAIN, INSTANCE_POLICY, SUMMARY)
#endif

#ifndef TSI_PATH_LANE
#define TSI_PATH_LANE(TYPE_ID, DIR, DIRECTIVE_ID, KIND, SUMMARY)
#endif

#ifndef TSI_PATH_ENDPOINT
#define TSI_PATH_ENDPOINT(TYPE_ID, DIRECTIVE_ID, KIND, SUMMARY)
#endif

// Canonical TSI dataflow directives used by:
// - runtime-binding hop DSL directive parsing
// - canonical path endpoint normalization
// - tsi directive ids
TSI_PATH_DIRECTIVE(Step, "@impulse", "Primary ingress impulse lane")
TSI_PATH_DIRECTIVE(Payload, "@response", "Primary response lane")
TSI_PATH_DIRECTIVE(Future, "@future", "Future payload lane")
TSI_PATH_DIRECTIVE(Loss, "@loss", "Training loss lane")
TSI_PATH_DIRECTIVE(Meta, "@meta", "Runtime trace/meta lane")
TSI_PATH_DIRECTIVE(Info, "@info", "Info lane (log sinks)")
TSI_PATH_DIRECTIVE(Warn, "@warn", "Warn lane (log sinks)")
TSI_PATH_DIRECTIVE(Debug, "@debug", "Debug lane (log sinks)")
TSI_PATH_DIRECTIVE(Error, "@error", "Error lane (log sinks)")
// Runtime-binding control directives and methods live in
// `iitepi/runtime_binding/runtime_binding.paths.def`.

// TSI component manifest.
// INSTANCE_POLICY:
// - `UniquePerCircuit`: only one instance of this tsi type in a circuit.
// - `ManyInstances`: any number of instances.
// - `HashimyeiInstances`: many instances keyed by <hashimyei>.
TSI_PATH_COMPONENT(SourceDataloader, "tsi.source.dataloader", Source,
                   ManyInstances, "Source dataloader component")
TSI_PATH_COMPONENT(WikimyeiRepresentationEncodingVicreg,
                   "tsi.wikimyei.representation.encoding.vicreg", Wikimyei,
                   HashimyeiInstances, "VICReg representation wikimyei")
TSI_PATH_COMPONENT(WikimyeiInferenceExpectedValueMdn,
                   "tsi.wikimyei.inference.expected_value.mdn", Wikimyei,
                   HashimyeiInstances, "MDN expected-value inference wikimyei")
TSI_PATH_COMPONENT(SinkNull, "tsi.sink.null", Sink, ManyInstances,
                   "Null sink terminal")
TSI_PATH_COMPONENT(SinkLogSys, "tsi.probe.log", Sink, UniquePerCircuit,
                   "Probe log sink")

// Per-component directive lanes (direction + cast kind).
TSI_PATH_LANE(SourceDataloader, In, Step, String, "source command ingress")
TSI_PATH_LANE(SourceDataloader, Out, Payload, Cargo,
              "source observation cargo payload")
TSI_PATH_LANE(SourceDataloader, Out, Meta, String, "runtime trace/meta stream")

TSI_PATH_LANE(WikimyeiRepresentationEncodingVicreg, In, Step, Cargo,
              "representation observation cargo ingress")
TSI_PATH_LANE(WikimyeiRepresentationEncodingVicreg, Out, Payload, Cargo,
              "representation observation cargo with encoding")
TSI_PATH_LANE(WikimyeiRepresentationEncodingVicreg, Out, Loss, Tensor,
              "training loss")
TSI_PATH_LANE(WikimyeiRepresentationEncodingVicreg, Out, Meta, String,
              "runtime trace/meta stream")

TSI_PATH_LANE(WikimyeiInferenceExpectedValueMdn, In, Step, Cargo,
              "expected-value inference cargo ingress")
TSI_PATH_LANE(WikimyeiInferenceExpectedValueMdn, Out, Payload, Cargo,
              "expected-value inference cargo passthrough")
TSI_PATH_LANE(WikimyeiInferenceExpectedValueMdn, Out, Future, Tensor,
              "conditional expectation E[F|X]")
TSI_PATH_LANE(WikimyeiInferenceExpectedValueMdn, Out, Loss, Tensor,
              "MDN training loss")
TSI_PATH_LANE(WikimyeiInferenceExpectedValueMdn, Out, Meta, String,
              "runtime trace/meta stream")

TSI_PATH_LANE(SinkNull, In, Step, Cargo, "sink consume step cargo")
TSI_PATH_LANE(SinkNull, Out, Meta, String, "runtime trace/meta stream")

TSI_PATH_LANE(SinkLogSys, In, Info, Tensor, "log info tensor payloads")
TSI_PATH_LANE(SinkLogSys, In, Info, Cargo, "log info cargo payloads")
TSI_PATH_LANE(SinkLogSys, In, Warn, String, "log warning messages")
TSI_PATH_LANE(SinkLogSys, In, Warn, Cargo, "log warning cargo payloads")
TSI_PATH_LANE(SinkLogSys, In, Debug, String, "log debug/meta messages")
TSI_PATH_LANE(SinkLogSys, In, Debug, Cargo, "log debug cargo payloads")
TSI_PATH_LANE(SinkLogSys, In, Error, String, "log error messages")
TSI_PATH_LANE(SinkLogSys, In, Error, Cargo, "log error cargo payloads")

// Canonical endpoint compatibility manifest.
// This list is used for endpoint-level path validation (known tsi types).
TSI_PATH_ENDPOINT(SourceDataloader, Step, String, "source command ingress")
TSI_PATH_ENDPOINT(SourceDataloader, Payload, Cargo,
                  "source observation cargo payload")
TSI_PATH_ENDPOINT(SourceDataloader, Meta, String, "runtime trace/meta stream")

TSI_PATH_ENDPOINT(WikimyeiRepresentationEncodingVicreg, Step, Cargo,
                  "representation observation cargo ingress")
TSI_PATH_ENDPOINT(WikimyeiRepresentationEncodingVicreg, Payload, Cargo,
                  "representation observation cargo with encoding")
TSI_PATH_ENDPOINT(WikimyeiRepresentationEncodingVicreg, Loss, Tensor,
                  "training loss")
TSI_PATH_ENDPOINT(WikimyeiRepresentationEncodingVicreg, Meta, String,
                  "runtime trace/meta stream")

TSI_PATH_ENDPOINT(WikimyeiInferenceExpectedValueMdn, Step, Cargo,
                  "expected-value inference cargo ingress")
TSI_PATH_ENDPOINT(WikimyeiInferenceExpectedValueMdn, Payload, Cargo,
                  "expected-value inference cargo passthrough")
TSI_PATH_ENDPOINT(WikimyeiInferenceExpectedValueMdn, Future, Tensor,
                  "conditional expectation E[F|X]")
TSI_PATH_ENDPOINT(WikimyeiInferenceExpectedValueMdn, Loss, Tensor,
                  "MDN training loss")
TSI_PATH_ENDPOINT(WikimyeiInferenceExpectedValueMdn, Meta, String,
                  "runtime trace/meta stream")

TSI_PATH_ENDPOINT(SinkNull, Step, Cargo, "sink consume step cargo")
TSI_PATH_ENDPOINT(SinkNull, Meta, String, "runtime trace/meta stream")

TSI_PATH_ENDPOINT(SinkLogSys, Info, Tensor, "log info tensor payloads")
TSI_PATH_ENDPOINT(SinkLogSys, Info, Cargo, "log info cargo payloads")
TSI_PATH_ENDPOINT(SinkLogSys, Warn, String, "log warning messages")
TSI_PATH_ENDPOINT(SinkLogSys, Warn, Cargo, "log warning cargo payloads")
TSI_PATH_ENDPOINT(SinkLogSys, Debug, String, "log debug/meta messages")
TSI_PATH_ENDPOINT(SinkLogSys, Debug, Cargo, "log debug cargo payloads")
TSI_PATH_ENDPOINT(SinkLogSys, Error, String, "log error messages")
TSI_PATH_ENDPOINT(SinkLogSys, Error, Cargo, "log error cargo payloads")

#undef TSI_PATH_LANE
#undef TSI_PATH_ENDPOINT
#undef TSI_PATH_COMPONENT
#undef TSI_PATH_METHOD
