#ifndef IINUJI_CANONICAL_CALL
#error                                                                         \
    "IINUJI_CANONICAL_CALL(ID, TEXT, SUMMARY) must be defined before including iinuji.paths.def"
#endif

#ifndef IINUJI_CANONICAL_ALIAS
#define IINUJI_CANONICAL_ALIAS(ID, ...)
#endif

#ifndef IINUJI_CANONICAL_PATTERN
#define IINUJI_CANONICAL_PATTERN(ID, TEXT, SUMMARY, MATCH_STYLE)
#endif

// System / shell lifecycle.
IINUJI_CANONICAL_CALL(HelpOpen, "iinuji.help()",
                      "Open help overlay in widescreen mode")
IINUJI_CANONICAL_CALL(HelpClose, "iinuji.help.close()", "Close help overlay")
