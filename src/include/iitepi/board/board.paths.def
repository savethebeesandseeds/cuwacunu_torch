#ifndef BOARD_PATH_DIRECTIVE
#error "BOARD_PATH_DIRECTIVE(ID, TOKEN, SUMMARY) must be defined before including board.paths.def"
#endif

#ifndef BOARD_PATH_METHOD
#define BOARD_PATH_METHOD(ID, TOKEN, SUMMARY)
#endif

#ifndef BOARD_PATH_ACTION
#define BOARD_PATH_ACTION(ID, TOKEN, SUMMARY)
#endif

#ifndef BOARD_PATH_DSL_SEGMENT
#define BOARD_PATH_DSL_SEGMENT(ID, KEY, SUMMARY)
#endif

#define RUNTIME_BINDING_PATH_DIRECTIVE(ID, TOKEN, SUMMARY) \
  BOARD_PATH_DIRECTIVE(ID, TOKEN, SUMMARY)
#define RUNTIME_BINDING_PATH_METHOD(ID, TOKEN, SUMMARY) \
  BOARD_PATH_METHOD(ID, TOKEN, SUMMARY)
#define RUNTIME_BINDING_PATH_ACTION(ID, TOKEN, SUMMARY) \
  BOARD_PATH_ACTION(ID, TOKEN, SUMMARY)
#define RUNTIME_BINDING_PATH_DSL_SEGMENT(ID, KEY, SUMMARY) \
  BOARD_PATH_DSL_SEGMENT(ID, KEY, SUMMARY)

#include "iitepi/runtime_binding/runtime_binding.paths.def"

#undef RUNTIME_BINDING_PATH_DSL_SEGMENT
#undef RUNTIME_BINDING_PATH_ACTION
#undef RUNTIME_BINDING_PATH_METHOD
#undef RUNTIME_BINDING_PATH_DIRECTIVE

#undef BOARD_PATH_DSL_SEGMENT
#undef BOARD_PATH_ACTION
#undef BOARD_PATH_METHOD
#undef BOARD_PATH_DIRECTIVE
