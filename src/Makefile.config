# =============================================================================
# Makefile.config — project-wide build configuration & reusable leaf rules
#
# This file is shared by:
#   • test leaf Makefiles under /src/tests/bench/...
#   • operator/runtime binaries under /src/main/tools
#   • interactive/operator interfaces under /src/main/interface
#   • HERO binaries under /src/main/hero
#
# It provides:
#   • toolchain flags, include paths, linker libs
#   • reliable .d dependency tracking
#   • tiny leaf Makefiles via a generic one-file binary helper
#   • per-module static archives reused by every leaf binary
#   • a dispatcher helper that builds first, then runs
# =============================================================================

# -----------------------------------------------------------------------------
# 0) Toolchain & Core Flags
# -----------------------------------------------------------------------------
CXX          := g++
CXX_STANDARD := c++20

COMMON_WARN  := -Wall -Wno-unused-function
DEBUG_FLAGS  := -g -Og -fno-omit-frame-pointer -rdynamic

# Compile-time hardening (objects)
SEC_CFLAGS   := -fstack-protector-strong -D_FORTIFY_SOURCE=2 -fPIC
# Link-time hardening (executables)
SEC_LDFLAGS  := -pie -fPIE

CXXFLAGS     += -std=$(CXX_STANDARD) $(COMMON_WARN) $(DEBUG_FLAGS) $(SEC_CFLAGS)
LDFLAGS      += $(SEC_LDFLAGS)

# -----------------------------------------------------------------------------
# 0.A) Runtime Toggles
# -----------------------------------------------------------------------------
# Keep project identity defaults unless explicitly overridden.
SECURE_LOCAL_CLEAN ?= 1
HASH_ARTIFACT_LOG ?= 1

# -----------------------------------------------------------------------------
# 0.1) SHOW_CMD toggle
# -----------------------------------------------------------------------------
SHOW_CMD ?= 0
SHOW_CMD_ON := $(filter 1 yes true on,$(strip $(SHOW_CMD)))
Q := $(if $(SHOW_CMD_ON),,@)

ifeq ($(SHOW_CMD_ON),)
  MAKEFLAGS += --no-builtin-rules --no-print-directory -s
else
  MAKEFLAGS += --no-builtin-rules --no-print-directory
endif

# Propagate the toggle to any sub-makes (important for the dispatcher)
MAKEFLAGS += SHOW_CMD=$(SHOW_CMD)

# -----------------------------------------------------------------------------
# 0.2) Optional parallel build control
# -----------------------------------------------------------------------------
# Usage:
#   PARALLEL_BUILD=1 make ...
#   PARALLEL_BUILD=1 PARALLEL_JOBS=9 make ...
# Defaults:
#   - on (uses parallel jobs by default)
#   - if PARALLEL_JOBS=0 and PARALLEL_BUILD=1, use detected CPU count
PARALLEL_BUILD ?= 1
PARALLEL_BUILD_ON := $(filter 1 yes true on,$(strip $(PARALLEL_BUILD)))
PARALLEL_JOBS ?= 0

ifeq ($(PARALLEL_BUILD_ON),1)
  # Only top-level make invocation injects -j.
  # Recursive sub-makes should inherit and honor the jobserver.
  ifeq ($(MAKELEVEL),0)
    ifeq ($(strip $(PARALLEL_JOBS)),0)
      PARALLEL_JOBS := $(strip $(shell nproc 2>/dev/null || getconf _NPROCESSORS_ONLN 2>/dev/null || sysctl -n hw.ncpu 2>/dev/null || echo 1))
    endif
    # Avoid duplicating explicit -j flags from command line.
    ifeq ($(filter -j% --jobs%,$(MAKEFLAGS)),)
      MAKEFLAGS += -j$(PARALLEL_JOBS)
    endif
  endif
endif

# -----------------------------------------------------------------------------
# 0.3) Compiler/Linker Commands
# -----------------------------------------------------------------------------
CXX_COMPILE = $(CXX)
CXX_LINK    = $(CXX)
LDFLAGS_E   = $(LDFLAGS)

INFO_COLOR_SOFT_GRAY := $(shell printf '\033[90m')
INFO_COLOR_RESET     := $(shell printf '\033[0m')
INFO_COLOR_YELLOW    := $(shell printf '\033[2;33m')
INFO_COLOR_BLUE      := $(shell printf '\033[34m')

ifeq ($(MAKELEVEL),0)
  $(info $(INFO_COLOR_YELLOW)[$(INFO_COLOR_SOFT_GRAY)BUILD:$(INFO_COLOR_BLUE)MODE$(INFO_COLOR_YELLOW)]$(INFO_COLOR_SOFT_GRAY) PARALLEL_BUILD=$(PARALLEL_BUILD) secure_clean=$(SECURE_LOCAL_CLEAN) hash_log=$(HASH_ARTIFACT_LOG)$(INFO_COLOR_RESET))
endif

# -----------------------------------------------------------------------------
# 1) Project Layout
# -----------------------------------------------------------------------------
SRC_ROOT     := $(abspath $(ROOT_PATH))
PROJECT_ROOT := $(abspath $(SRC_ROOT)/..)
BUILD_ROOT   := $(PROJECT_ROOT)/.build

OUTPUT_PATH := $(BUILD_ROOT)/obj
# Object/dependency workspace for compiled translation units and build metadata.
# Bundled static archives live separately under LIB_OUT.
# Default leaf-binary output root. Test leaf Makefiles use the default tests
# path directly; production leaf Makefiles usually override BIN_OUT to a
# clearer local path (for example BIN_OUT := $(TOOLS_OUT)).
BIN_OUT     ?= $(BUILD_ROOT)/tests
# Compatibility alias for the tests tree and older leaf Makefiles that still
# refer to TEST_OUT explicitly.
TEST_OUT    ?= $(BIN_OUT)
LIB_OUT     := $(BUILD_ROOT)/lib
HERO_OUT    := $(BUILD_ROOT)/hero
TOOLS_OUT   := $(BUILD_ROOT)/tools
INTERFACE_OUT := $(BUILD_ROOT)/interface
CLEAN_HELPER := $(SRC_ROOT)/scripts/guarded_clean.sh
CLEAN_RM_CMD := bash "$(CLEAN_HELPER)" rm "$(BUILD_ROOT)"
CLEAN_SHRED_CMD := bash "$(CLEAN_HELPER)" shred "$(BUILD_ROOT)"
CLEAN_TREE_CMD := bash "$(CLEAN_HELPER)" clean-tree "$(BUILD_ROOT)"

IMPL_PATH   := $(ROOT_PATH)/impl
CONFIG_PATH := $(ROOT_PATH)/config
TESTS_PATH  := $(ROOT_PATH)/tests

# Absolute path (avoids // and mismatched -C sub-makes)
TESTS_PATH_ABS := $(abspath $(TESTS_PATH))

# Internal bridge: when a leaf or main build needs fresh archives, always
# refresh them through the canonical src/ aggregate instead of owning a second
# modules graph locally.
.PHONY: refresh-src-lib-bundles
refresh-src-lib-bundles:
	$(Q)+$(MAKE) -C $(SRC_ROOT) lib-bundles

# -----------------------------------------------------------------------------
# 2) External SDK Locations
# -----------------------------------------------------------------------------
EXTERNAL_LIBS_PATH := /cuwacunu/.external
LIBTORCH_DIRNAME   ?= libtorch-upd
LIBTORCH_PATH      := $(EXTERNAL_LIBS_PATH)/$(LIBTORCH_DIRNAME)
LIBCUDA_PATH       := /usr/local/cuda-12.4
SSL_PATH           := /usr
SYSTEM_CURL_PATH   := /usr
LIBCURL_PATH       ?= $(EXTERNAL_LIBS_PATH)/curl-8.9.1

ifneq ($(wildcard $(LIBCURL_PATH)/include/curl/curl.h),)
  LIBCURL_INCLUDE_ROOT := $(LIBCURL_PATH)/include
else
  LIBCURL_INCLUDE_ROOT := $(SYSTEM_CURL_PATH)/include
endif

ifneq ($(wildcard $(LIBCURL_PATH)/lib/.libs/libcurl.so),)
  LIBCURL_LIB_PATH := $(LIBCURL_PATH)/lib/.libs
else ifneq ($(wildcard $(LIBCURL_PATH)/lib/.libs/libcurl.a),)
  LIBCURL_LIB_PATH := $(LIBCURL_PATH)/lib/.libs
else
  LIBCURL_LIB_PATH := $(SYSTEM_CURL_PATH)/lib/x86_64-linux-gnu
endif

# -----------------------------------------------------------------------------
# 3) Include Paths
# -----------------------------------------------------------------------------
USUAL_INCLUDE_PATHS   := -I$(SRC_ROOT) -I$(SRC_ROOT)/include -I$(SRC_ROOT)/include/torch_compat
TORCH_INCLUDE_PATHS   := -I$(LIBTORCH_PATH)/include -I$(LIBTORCH_PATH)/include/torch/csrc/api/include -I$(LIBCUDA_PATH)/include
SSL_INCLUDE_PATHS     := -I$(SSL_PATH)/include
LIBCURL_INCLUDE_PATHS := -I$(LIBCURL_INCLUDE_ROOT)
NCURSES_INCLUDE_PATHS := -I/usr/include/ncursesw

# -----------------------------------------------------------------------------
# 4) Link Libraries (system libs)
# -----------------------------------------------------------------------------
# NOTE: g++ links libstdc++ automatically; we keep -lstdc++ for clarity.
LDLIBS_common := -lstdc++ -lpthread -lm

LDLIBS_torch := -L$(LIBTORCH_PATH)/lib -L$(LIBCUDA_PATH)/lib64
LDLIBS_torch += -Wl,-rpath,$(LIBTORCH_PATH)/lib
LDLIBS_torch += -Wl,-rpath,$(LIBCUDA_PATH)/lib64
# Keep CUDA hooks resident even when no direct undefined symbol pulls them in.
# Without this, some linkers drop libtorch_cuda/libc10_cuda and
# torch::cuda::is_available() falls back to the CPU-only hooks.
LDLIBS_torch += -Wl,--no-as-needed -ltorch_cuda -lc10_cuda -Wl,--as-needed
LDLIBS_torch += -ltorch_cpu -ltorch -lc10
LDLIBS_torch += -lcuda -lcudart -lnvToolsExt

LDLIBS_ssl  := -L$(SSL_PATH)/lib/x86_64-linux-gnu/ -lcrypto -lssl
LDLIBS_curl := -L$(LIBCURL_LIB_PATH) -Wl,-rpath,$(LIBCURL_LIB_PATH) -lcurl

# Keep original naming for ncurses compatibility across the tests tree
LDLIBS_ncurses := -lncursesw
# If your distro needs it, uncomment:
# LDLIBS_ncurses := -lncursesw -ltinfo

# -----------------------------------------------------------------------------
# 5) Dependency (.d) Files
# -----------------------------------------------------------------------------
DEPDIR := $(OUTPUT_PATH)/.deps
OBJTMP := $(OUTPUT_PATH)/.objs
TIMERDIR := $(OUTPUT_PATH)/.timers
LOCKDIR := $(OUTPUT_PATH)/.locks

# One-time depfile migration after runtime tree renames.
# Old depfiles embed cwd-relative paths and can break parent aggregators.
DEPS_MIGRATION_STAMP := $(BUILD_ROOT)/.deps_migrated_paths_v3
ifeq ($(wildcard $(DEPS_MIGRATION_STAMP)),)
  $(shell set -e; \
    if [ -d "$(DEPDIR)" ]; then \
      find "$(DEPDIR)" -type f -name '*.d' -print0 2>/dev/null \
      | xargs -0 -r grep -lE '(/src/cuwacunu/|/src/main/tests/|[[:space:]]\.\./\.\./cuwacunu/|[[:space:]]\.\./\.\./\.\./\.\./cuwacunu/tests/)' 2>/dev/null \
      | xargs -r rm -f; \
      find "$(DEPDIR)" -type f -name '*.o:.o=.d' -delete 2>/dev/null || true; \
    fi; \
    mkdir -p "$(dir $(DEPS_MIGRATION_STAMP))"; \
    : > "$(DEPS_MIGRATION_STAMP)")
endif

# Object rules (CC_RULE) write depfiles alongside $(OUTPUT_PATH) tree
DEPFILE  = $(DEPDIR)/$(patsubst %.o,%.d,$(@:$(OUTPUT_PATH)/%=%))
DEPFLAGS = -MMD -MP -MF $(DEPFILE) -MT $@
TIMERFILE = $(TIMERDIR)/$(subst :,_,$(subst /,_,$@)).$$PPID.start_ns
CLEAN_LOCKFILE = $(LOCKDIR)/$(subst :,_,$(subst /,_,$(abspath $@))).clean.lock

# Include all known depfiles (safe if none exist yet)
-include $(shell test -d $(DEPDIR) && find $(DEPDIR) -name '*.d' -print)

# -----------------------------------------------------------------------------
# 6) Logging (with runtime hashes + elapsed build time)
# -----------------------------------------------------------------------------
COLOR_GREEN      := \033[32m
COLOR_DIM_GREEN  := \033[2;32m
COLOR_YELLOW     := \033[33m
COLOR_DIM_YELLOW := \033[2;33m
COLOR_RED        := \033[31m
COLOR_GRAY       := \033[90m
COLOR_BLUE       := \033[34m
COLOR_MAHOGANY_RED := \033[38;2;128;40;30m
COLOR_RESET      := \033[0m

LOG_START = { \
  mkdir -p "$(TIMERDIR)"; \
  now_ns="$$(date +%s%N 2>/dev/null || true)"; \
  case "$$now_ns" in ''|*[!0-9]*) now_ns="$$(date +%s)000000000" ;; esac; \
  printf '%s\n' "$$now_ns" > "$(TIMERFILE)"; \
  printf "$(COLOR_DIM_YELLOW)[$(COLOR_GRAY)OBJ: $(COLOR_DIM_YELLOW)BUILD]$(COLOR_RESET)  \
$(COLOR_GRAY)%-70s request to build.$(COLOR_RESET)\n" "$(notdir $@)"; \
}

HASH_ARTIFACT_LOG_ON := $(filter 1 yes true on,$(strip $(HASH_ARTIFACT_LOG)))
ifeq ($(HASH_ARTIFACT_LOG_ON),1)
LOG_END = { \
  start_ns="$$(cat "$(TIMERFILE)" 2>/dev/null || true)"; \
  now_ns="$$(date +%s%N 2>/dev/null || true)"; \
  case "$$now_ns" in ''|*[!0-9]*) now_ns="$$(date +%s)000000000" ;; esac; \
  case "$$start_ns" in ''|*[!0-9]*) start_ns='' ;; esac; \
  elapsed_human="n/a"; \
  if [ -n "$$start_ns" ]; then \
    elapsed_ns="$$((now_ns - start_ns))"; \
    if [ "$$elapsed_ns" -lt 0 ]; then elapsed_ns=0; fi; \
    elapsed_human="$$(awk -v ns="$$elapsed_ns" 'BEGIN { s=ns/1000000000.0; h=int(s/3600); s-=h*3600; m=int(s/60); s-=m*60; if (h>0) printf "%dh %dm %.3fs",h,m,s; else if (m>0) printf "%dm %.3fs",m,s; else if (s>=1.0) printf "%.3fs",s; else printf "%.0fms",s*1000; }')"; \
  fi; \
  rm -f "$(TIMERFILE)" 2>/dev/null || true; \
  sha="$$(sha256sum '$@' 2>/dev/null | awk '{print $$1}')"; \
  md5="$$(md5sum    '$@' 2>/dev/null | awk '{print $$1}')"; \
  printf "$(COLOR_DIM_YELLOW)[$(COLOR_GRAY)OBJ: $(COLOR_DIM_GREEN)   OK$(COLOR_DIM_YELLOW)]$(COLOR_RESET)  \
$(COLOR_GRAY)%-70s $(COLOR_GRAY)[$(COLOR_DIM_YELLOW)time:$(COLOR_GRAY)%s][$(COLOR_DIM_YELLOW)sha256:$(COLOR_GRAY)%s][$(COLOR_DIM_YELLOW)md5:$(COLOR_GRAY)%s]$(COLOR_RESET)\n" "$(notdir $@)" "$$elapsed_human" "$$sha" "$$md5"; \
} || printf "$(COLOR_DIM_YELLOW)    [OBJ:$(COLOR_RED)FAIL$(COLOR_DIM_YELLOW) ]$(COLOR_RESET)  %-20s (exit %s)\n" \
       "$(notdir $@)" "$$?"
else
LOG_END = { \
  start_ns="$$(cat "$(TIMERFILE)" 2>/dev/null || true)"; \
  now_ns="$$(date +%s%N 2>/dev/null || true)"; \
  case "$$now_ns" in ''|*[!0-9]*) now_ns="$$(date +%s)000000000" ;; esac; \
  case "$$start_ns" in ''|*[!0-9]*) start_ns='' ;; esac; \
  elapsed_human="n/a"; \
  if [ -n "$$start_ns" ]; then \
    elapsed_ns="$$((now_ns - start_ns))"; \
    if [ "$$elapsed_ns" -lt 0 ]; then elapsed_ns=0; fi; \
    elapsed_human="$$(awk -v ns="$$elapsed_ns" 'BEGIN { s=ns/1000000000.0; h=int(s/3600); s-=h*3600; m=int(s/60); s-=m*60; if (h>0) printf "%dh %dm %.3fs",h,m,s; else if (m>0) printf "%dm %.3fs",m,s; else if (s>=1.0) printf "%.3fs",s; else printf "%.0fms",s*1000; }')"; \
  fi; \
  rm -f "$(TIMERFILE)" 2>/dev/null || true; \
  printf "$(COLOR_DIM_YELLOW)[$(COLOR_GRAY)OBJ: $(COLOR_DIM_GREEN)   OK$(COLOR_DIM_YELLOW)]$(COLOR_RESET)  \
$(COLOR_GRAY)%-70s $(COLOR_GRAY)[$(COLOR_DIM_YELLOW)time:$(COLOR_GRAY)%s]$(COLOR_RESET)\n" "$(notdir $@)" "$$elapsed_human"; \
} || printf "$(COLOR_DIM_YELLOW)    [OBJ:$(COLOR_RED)FAIL$(COLOR_DIM_YELLOW) ]$(COLOR_RESET)  %-20s (exit %s)\n" \
       "$(notdir $@)" "$$?"
endif

# Remove stale output before re-creating (defends against stray files)
SECURE_LOCAL_CLEAN_ON := $(filter 1 yes true on,$(strip $(SECURE_LOCAL_CLEAN)))
ifeq ($(SECURE_LOCAL_CLEAN_ON),1)
LOCAL_CLEAN = { \
  tgt="$(abspath $@)"; \
  lock="$(CLEAN_LOCKFILE)"; \
  mkdir -p "$(LOCKDIR)"; \
  lock_wait_start="$$(date +%s 2>/dev/null || echo 0)"; \
  while ! mkdir "$$lock" 2>/dev/null; do \
    now_s="$$(date +%s 2>/dev/null || echo 0)"; \
    case "$$now_s" in ''|*[!0-9]*) now_s=0 ;; esac; \
    case "$$lock_wait_start" in ''|*[!0-9]*) lock_wait_start=0 ;; esac; \
    waited_s="$$((now_s - lock_wait_start))"; \
    if [ "$$waited_s" -ge 30 ]; then \
      owner_pid="$$(cat "$$lock/pid" 2>/dev/null || true)"; \
      case "$$owner_pid" in ''|*[!0-9]*) owner_pid=0 ;; esac; \
      if [ "$$owner_pid" -eq 0 ] || ! kill -0 "$$owner_pid" 2>/dev/null; then \
        rm -f -- "$$lock/pid" 2>/dev/null || true; \
        rmdir "$$lock" 2>/dev/null || true; \
      fi; \
    fi; \
    if [ "$$waited_s" -ge 180 ]; then \
      owner_pid="$$(cat "$$lock/pid" 2>/dev/null || true)"; \
      printf "$(COLOR_DIM_YELLOW)[$(COLOR_GRAY)LOCK:$(COLOR_RED)WAIT$(COLOR_DIM_YELLOW)]$(COLOR_RESET) target=%s lock=%s wait=%ss owner_pid=%s\n" \
        "$$tgt" "$$lock" "$$waited_s" "$${owner_pid:-unknown}"; \
      exit 1; \
    fi; \
    sleep 0.02; \
  done; \
  printf '%s\n' "$$$$" > "$$lock/pid" 2>/dev/null || true; \
  trap 'rm -f -- "$$lock/pid" 2>/dev/null || true; rmdir "$$lock" 2>/dev/null || true' EXIT INT TERM; \
  if [ -e "$$tgt" ]; then \
    pre_stat="$$(stat -Lc 'inode=%i size=%s mtime=%Y nlink=%h' -- "$$tgt" 2>/dev/null || echo 'stat_unavailable')"; \
    if [ -f "$$tgt" ] && [ -x "$$tgt" ]; then \
      if ! $(CLEAN_RM_CMD) "$$tgt"; then \
        rc="$$?"; \
        printf "$(COLOR_DIM_YELLOW)[$(COLOR_GRAY)SRED:$(COLOR_RED)FAIL$(COLOR_DIM_YELLOW)]$(COLOR_RESET) target=%s cwd=%s pid=%s rc=%s pre={%s}\n" \
          "$$tgt" "$$(pwd)" "$$$$" "$$rc" "$$pre_stat"; \
        exit "$$rc"; \
      fi; \
      if [ -e "$$tgt" ]; then \
        printf "$(COLOR_DIM_YELLOW)[$(COLOR_GRAY)SRED:$(COLOR_RED)FAIL$(COLOR_DIM_YELLOW)]$(COLOR_RESET) target=%s cwd=%s pid=%s rc=exec_unlink_failed pre={%s}\n" \
          "$$tgt" "$$(pwd)" "$$$$" "$$pre_stat"; \
        exit 1; \
      fi; \
    elif ! $(CLEAN_SHRED_CMD) "$$tgt"; then \
      rc="$$?"; \
      fallback_rc=0; \
      $(CLEAN_RM_CMD) "$$tgt" || fallback_rc="$$?"; \
      if [ "$$fallback_rc" -ne 0 ] || [ -e "$$tgt" ]; then \
        printf "$(COLOR_DIM_YELLOW)[$(COLOR_GRAY)SRED:$(COLOR_RED)FAIL$(COLOR_DIM_YELLOW)]$(COLOR_RESET) target=%s cwd=%s pid=%s rc=%s pre={%s}\n" \
          "$$tgt" "$$(pwd)" "$$$$" "$$rc" "$$pre_stat"; \
        exit "$$rc"; \
      fi; \
      printf "$(COLOR_DIM_YELLOW)[$(COLOR_GRAY)SRED:$(COLOR_BLUE)WARN$(COLOR_DIM_YELLOW)]$(COLOR_RESET) target=%s cwd=%s pid=%s rc=%s fallback=unlink pre={%s}\n" \
        "$$tgt" "$$(pwd)" "$$$$" "$$rc" "$$pre_stat"; \
    fi; \
  fi; \
  trap - EXIT INT TERM; \
  rm -f -- "$$lock/pid" 2>/dev/null || true; \
  rmdir "$$lock" 2>/dev/null || true; \
}
else
LOCAL_CLEAN = { $(CLEAN_RM_CMD) "$@"; }
endif

# Optional run modes (tests may override RUN_MODE)
PLAIN     :=
GDB       := gdb -ex "set print thread-events off" -ex run
GDB_TORCH := CUDA_LAUNCH_BLOCKING=1 TORCH_SHOW_CPP_STACKTRACES=1 $(GDB)
VALGRIND  := valgrind --leak-check=full -s --show-leak-kinds=all \
               --suppressions=$(CONFIG_PATH)/valgrind.supp \
               --gen-suppressions=all \
               --log-file=$(ROOT_PATH)/src/valgrind.log
RUN_MODE  = $(PLAIN)

# -----------------------------------------------------------------------------
# 7) Central Build Rules (split lines so g++ shows clearly)
# -----------------------------------------------------------------------------
define CC_RULE
	$(Q)mkdir -p $(@D) $(DEPDIR) $(dir $(DEPFILE))
	$(Q)$(LOG_START)
	$(Q)$(LOCAL_CLEAN)
	$(Q)$(CXX_COMPILE) $(CXXFLAGS) $(DEPFLAGS) \
	      $(USUAL_INCLUDE_PATHS) $(INCLUDES_EXTRA) \
	      -c $(abspath $<) -o $@
	$(Q)$(LOG_END)
endef

define ONEFILE_EXE_RULE
	$(Q)mkdir -p $(@D) $(DEPDIR) $(dir $(DEPFILE))
	$(Q)$(LOG_START)
	$(Q)$(LOCAL_CLEAN)
	$(Q)$(CXX_COMPILE) $(CXXFLAGS) $(DEPFLAGS) \
	      $(USUAL_INCLUDE_PATHS) $(INCLUDES_EXTRA) \
	      -c $(abspath $<) -o $(OBJTMP)/$(basename $(notdir $@)).o
	$(Q)$(CXX_LINK) $(LDFLAGS_E) \
	      $(OBJTMP)/$(basename $(notdir $@)).o \
	      $(LDLIBS_common) $(LDLIBS_EXTRA) -o $@
	$(Q)$(LOG_END)
endef

define LINK_RULE
	$(Q)$(CXX_LINK) $(LDFLAGS_E) $^ $(LDLIBS_common) $(LDLIBS_EXTRA) -o $@
endef

# -----------------------------------------------------------------------------
# 8) Static archives — fast archive syncing
# -----------------------------------------------------------------------------
# IMPORTANT:
#  - We do NOT create empty .a files.
#  - AUTO_PREP only syncs linked archives from the current *.o set.
#  - It does not rebuild impl objects; that remains an explicit build step.

libcommon_a := $(LIB_OUT)/libcommon.a
libcurl_a   := $(LIB_OUT)/libcurlwrap.a
libssl_a    := $(LIB_OUT)/libsslwrap.a
libtorch_a  := $(LIB_OUT)/libtorchwrap.a

# Optional tracing of the shell body when SHOW_CMD=1
ifeq ($(SHOW_CMD_ON),)
  SH_TRACE :=
else
  SH_TRACE := set -x;
endif

# Smart repack helper:
#  - safe when dir missing / empty
#  - rebuilds archives from the current object set (never in-place)
#  - removes stale archives when a bundle no longer has object members

define MAYBE_PACK
	$(Q)$(SH_TRACE) \
	out="$(strip $(1))"; dir="$(strip $(2))"; tmp="$$out.tmp.$$$$"; \
	objs=""; \
	if [ -d "$$dir" ]; then \
	  objs="$$(find "$$dir" -type f -name '*.o' \
	    ! -path '*/dconfig/*' -print 2>/dev/null | LC_ALL=C sort)"; \
	fi; \
	if [ -n "$$objs" ]; then \
	  need=0; \
	  if [ ! -s "$$out" ]; then \
	    need=1; \
	  else \
	    current_members="$$(for f in $$objs; do printf '%s\n' "$${f##*/}"; done | LC_ALL=C sort)"; \
	    archive_members="$$( { $(AR) t "$$out" 2>/dev/null || true; } | LC_ALL=C sort )"; \
	    if [ "$$archive_members" != "$$current_members" ]; then \
	      need=1; \
	    else \
	      for f in $$objs; do \
	        if [ "$$f" -nt "$$out" ]; then need=1; break; fi; \
	      done; \
	    fi; \
	  fi; \
	  if [ $$need -eq 1 ]; then \
	    mkdir -p "$$(dirname "$$out")" || { echo "lib-bundles: mkdir failed for $$out" >&2; exit 1; }; \
	    rm -f -- "$$tmp"; \
	    $(AR) rcs "$$tmp" $$objs || { rm -f -- "$$tmp"; echo "lib-bundles: ar failed for $$out" >&2; exit 1; }; \
	    mv -f -- "$$tmp" "$$out" || { rm -f -- "$$tmp"; echo "lib-bundles: replace failed for $$out" >&2; exit 1; }; \
	    printf "$(COLOR_DIM_YELLOW)[$(COLOR_GRAY)MODULE: $(COLOR_DIM_GREEN)OK$(COLOR_DIM_YELLOW)]$(COLOR_RESET)  $(COLOR_GREEN)%s$(COLOR_RESET)\n" "$$out"; \
	  fi; \
	elif [ -e "$$out" ]; then \
	  rm -f -- "$$out" || { echo "lib-bundles: prune failed for $$out" >&2; exit 1; }; \
	  printf "$(COLOR_DIM_YELLOW)[$(COLOR_GRAY)MODULE: $(COLOR_BLUE)PRUNE$(COLOR_DIM_YELLOW)]$(COLOR_RESET)  $(COLOR_GREEN)%s$(COLOR_RESET)\n" "$$out"; \
	fi; :
endef

# and (optional but recommended) remove the cosmetic alignment spaces:
lib-bundles:
	$(call MAYBE_PACK,$(libcommon_a),$(OUTPUT_PATH)/common)
	$(call MAYBE_PACK,$(libcurl_a),$(OUTPUT_PATH)/libcurl)
	$(call MAYBE_PACK,$(libssl_a),$(OUTPUT_PATH)/openssl)
	$(call MAYBE_PACK,$(libtorch_a),$(OUTPUT_PATH)/libtorch)

# -----------------------------------------------------------------------------
# 9) Sugar Macros for Source Makefiles (producers)
# -----------------------------------------------------------------------------
define BUILD_OBJ
$$(OUTPUT_PATH)/$$(strip $(1))/$$(strip $(2)).o: \
	$$(HERE_PATH)/$$(strip $(2)).cpp \
	$$(HERE_PATH)/Makefile \
	$$(SRC_ROOT)/Makefile.config
	$$(CC_RULE)

.PHONY: $$(strip $(3))
$$(strip $(3)): $$(OUTPUT_PATH)/$$(strip $(1))/$$(strip $(2)).o
	$$(Q)printf "$(COLOR_DIM_YELLOW)[$(COLOR_GRAY)MODULE: $(COLOR_DIM_GREEN)OK$(COLOR_DIM_YELLOW)]$(COLOR_RESET)  $(COLOR_GREEN)%s/$(notdir $$@)$(COLOR_RESET)\n" "$(REL_MODULE)"
endef

define BUILD_OBJ_INC
$$(OUTPUT_PATH)/$$(strip $(1))/$$(strip $(2)).o: INCLUDES_EXTRA := $$(strip $(4))
$$(eval $$(call BUILD_OBJ,$$(strip $(1)),$$(strip $(2)),$$(strip $(3))))
endef

# -----------------------------------------------------------------------------
# 10) Leaf Binary Helpers (one-file binaries + dispatcher)
# -----------------------------------------------------------------------------
TEST_DEFAULT_LDLIBS ?= $(libcommon_a)

# ---- Fast archive-sync toggle ----
# Default: refresh linked archives automatically before linking.
# Use AUTO_PREP=0 only when you explicitly want manual archive management.
AUTO_PREP ?= 1

ifeq ($(AUTO_PREP),1)
  ORDER_PREP := autoprep
else
  ORDER_PREP :=
endif

.PHONY: autoprep
autoprep: refresh-src-lib-bundles

# ------------- ONEFILE_RULE -------------
define ONEFILE_RULE
.PHONY: clear-$(strip $(1))
clear-$(strip $(1)):
	$(Q)set -e; \
	depfile="$(DEPDIR)/$(strip $(1)).d"; \
	binary="$(BIN_OUT)/$(strip $(1))"; \
	objfile="$(OBJTMP)/$(strip $(1)).o"; \
	linkdeps="$(strip $(filter %.a,$(TEST_DEFAULT_LDLIBS) $(3)))"; \
	name="$(strip $(1))"; \
	if [ ! -f "$$$$depfile" ]; then exit 0; fi; \
	if [ ! -e "$$$$binary" ] && [ ! -e "$$$$objfile" ]; then exit 0; fi; \
	deps="`sed -e ':a' -e 'N' -e '$$!ba' -e 's/\\\n/ /g' "$$$$depfile" | sed -E 's/^[^:]+:[[:space:]]*//'`"; \
	need_clear=0; \
	for f in $$$$deps; do \
	  [ "$$$$f" = "\\" ] && continue; \
	  [ -e "$$$$f" ] || continue; \
	  if [ -e "$$$$binary" ] && [ "$$$$f" -nt "$$$$binary" ]; then need_clear=1; break; fi; \
	  if [ ! -e "$$$$binary" ] && [ -e "$$$$objfile" ] && [ "$$$$f" -nt "$$$$objfile" ]; then need_clear=1; break; fi; \
	done; \
	if [ "$$$$need_clear" -eq 0 ]; then \
	  for f in $$$$linkdeps; do \
	    [ -e "$$$$f" ] || continue; \
	    if [ -e "$$$$binary" ] && [ "$$$$f" -nt "$$$$binary" ]; then need_clear=1; break; fi; \
	    if [ ! -e "$$$$binary" ] && [ -e "$$$$objfile" ] && [ "$$$$f" -nt "$$$$objfile" ]; then need_clear=1; break; fi; \
	  done; \
	fi; \
	if [ "$$$$need_clear" -eq 1 ]; then \
	  $(CLEAN_RM_CMD) "$$$$binary" "$$$$objfile"; \
	  printf "$(COLOR_DIM_YELLOW)[$(COLOR_GRAY)CLR: $(COLOR_MAHOGANY_RED)STALE$(COLOR_DIM_YELLOW)]$(COLOR_RESET)  $(COLOR_GRAY)%-70s request to rebuild new version.$(COLOR_RESET)\n" "$$$$name"; \
	fi

# Source MUST be first prerequisite so the compile line is unambiguous.
$$(BIN_OUT)/$$(strip $(1)): \
	$$(HERE_PATH)/$$(strip $(2)) \
	$$(HERE_PATH)/Makefile \
	$$(SRC_ROOT)/Makefile.config \
	$$(filter %.a,$$(TEST_DEFAULT_LDLIBS) $(3)) $$(strip $(4))
	$(Q)mkdir -p $$(@D) $$(DEPDIR) $$(OBJTMP)
	$(Q)$$(LOG_START)
	$(Q)$$(LOCAL_CLEAN)
	# Compile the real source (explicit path avoids $< pitfalls)
	$(Q)$$(CXX_COMPILE) $$(CXXFLAGS) \
	      -MMD -MP -MF $$(DEPDIR)/$$(basename $$(notdir $$@)).d -MT $$@ \
	      $$(USUAL_INCLUDE_PATHS) $$(INCLUDES_EXTRA) \
	      -c $$(abspath $$(HERE_PATH)/$$(strip $(2))) -o $$(OBJTMP)/$$(basename $$(notdir $$@)).o
	# Link
	$(Q)$$(CXX_LINK) $$(LDFLAGS_E) \
	      $$(OBJTMP)/$$(basename $$(notdir $$@)).o \
	      $$(LDLIBS_common) \
	      -Wl,--start-group $$(filter %.a,$$(TEST_DEFAULT_LDLIBS) $(3)) -Wl,--end-group \
	      $$(filter-out %.a,$$(TEST_DEFAULT_LDLIBS) $(3)) $$(LDLIBS_EXTRA) \
	      -o $$@
	$(Q)$$(POST_LINK_HOOK)
	$(Q)$$(LOG_END)

.PHONY: run-$$(strip $(1))
run-$$(strip $(1)): $$(BIN_OUT)/$$(strip $(1))
	$(Q)$$(RUN_MODE) $$(BIN_OUT)/$$(strip $(1))
endef

# Production binaries still auto-refresh linked archives when AUTO_PREP=1.
define BIN_ONEFILE
$(call ONEFILE_RULE,$(1),$(2),$(3),| $$(ORDER_PREP))
endef

# Tests assume `make lib` already ran and only do the final compile/link step.
define TEST_ONEFILE
$(call ONEFILE_RULE,$(1),$(2),$(3))
endef

# -----------------------------------------------------------------------------
# 11) Dispatcher (build-first, then run)
#   Running `make -C tests test_<name> SHOW_CMD=1` shows g++ commands
#   whenever the test needs to be rebuilt.
#   Tests assume the required archives were already built with `make lib`.
# -----------------------------------------------------------------------------
# Set FORCE_TEST_REBUILD=1 to always rebuild test binaries before execution.
FORCE_TEST_REBUILD ?= 0
FORCE_TEST_REBUILD_ON := $(filter 1 yes true on,$(strip $(FORCE_TEST_REBUILD)))

define FORWARD_ONE
.PHONY: clear_$(1) clear-test_$(1)
clear_$(1) clear-test_$(1):
	$(Q)echo "$(COLOR_GRAY)[DISPATCH_CLEAR]$(COLOR_RESET) $(2)/test_$(1)"
	$(Q)+$(MAKE) -C $(2) clear-test_$(1)

.PHONY: test_$(1)
test_$(1):
	$(Q)echo "$(COLOR_DIM_YELLOW)[$(COLOR_GRAY)BUILD:$(COLOR_BLUE)TEST$(COLOR_DIM_YELLOW)]$(COLOR_RESET) $(2)/test_$(1)"
	# Optional force rebuild for debugging; default keeps existing binary.
	$(if $(FORCE_TEST_REBUILD_ON),$(Q)$(CLEAN_RM_CMD) '$(TEST_OUT)/test_$(1)')
	# Clear stale artifacts only when depfiles say sources/headers changed.
	$(Q)+$(MAKE) -C $(2) clear-test_$(1)
	# Build first (shows compile/link if anything is stale)
	$(Q)+{ \
	  $(MAKE) -C $(2) $(TEST_OUT)/test_$(1) || { \
	    echo "$(COLOR_GRAY)[HINT]$(COLOR_RESET) Build libraries first with 'make -C $(SRC_ROOT) lib' and then rerun this test."; \
	    exit 1; \
	  }; \
	}
	# Then run (kept separate to avoid hiding build commands)
	$(Q)+$(MAKE) -C $(2) run-test_$(1)
endef
