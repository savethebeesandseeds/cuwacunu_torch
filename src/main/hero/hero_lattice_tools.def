#ifndef HERO_LATTICE_MCP_TOOL
#error "HERO_LATTICE_MCP_TOOL(NAME, DESCRIPTION, INPUT_SCHEMA_JSON) must be defined before including hero_lattice_tools.def"
#endif

HERO_LATTICE_MCP_TOOL("hero.lattice.get_runs", "List run manifests filtered by wave-contract-binding hashimyei refs", "{\"type\":\"object\",\"properties\":{\"contract_hashimyei\":{\"type\":\"string\"},\"wave_hashimyei\":{\"type\":\"string\"},\"binding_hashimyei\":{\"type\":\"string\"},\"limit\":{\"type\":\"integer\"},\"offset\":{\"type\":\"integer\"}}}");
HERO_LATTICE_MCP_TOOL("hero.lattice.list_report_fragments", "List runtime report fragments for hashimyei_cursor (canonical_path alias accepted); supports intersection_cursor (hashimyei_cursor|wave_cursor) where wave_cursor may be packed integer or <run>.<epoch>,<batch>, and returns numeric + readable cursor views", "{\"type\":\"object\",\"properties\":{\"canonical_path\":{\"type\":\"string\"},\"hashimyei_cursor\":{\"type\":\"string\"},\"intersection_cursor\":{\"type\":\"string\"},\"schema\":{\"type\":\"string\"},\"wave_cursor\":{\"type\":\"string\"},\"wave_cursor_mask\":{\"type\":\"string\"},\"limit\":{\"type\":\"integer\"},\"offset\":{\"type\":\"integer\"}},\"anyOf\":[{\"required\":[\"canonical_path\"]},{\"required\":[\"hashimyei_cursor\"]},{\"required\":[\"intersection_cursor\"]}]}");
HERO_LATTICE_MCP_TOOL("hero.lattice.get_latest_report_fragment", "Fetch the latest runtime report fragment for hashimyei_cursor (canonical_path alias accepted) and schema; supports intersection_cursor (hashimyei_cursor|wave_cursor) where wave_cursor may be packed integer or <run>.<epoch>,<batch>", "{\"type\":\"object\",\"properties\":{\"canonical_path\":{\"type\":\"string\"},\"hashimyei_cursor\":{\"type\":\"string\"},\"intersection_cursor\":{\"type\":\"string\"},\"schema\":{\"type\":\"string\"},\"wave_cursor\":{\"type\":\"string\"},\"wave_cursor_mask\":{\"type\":\"string\"}},\"required\":[\"schema\"],\"anyOf\":[{\"required\":[\"canonical_path\"]},{\"required\":[\"hashimyei_cursor\"]},{\"required\":[\"intersection_cursor\"]}]}");
HERO_LATTICE_MCP_TOOL("hero.lattice.get_report_fragment", "Fetch one runtime report fragment by report_fragment_id", "{\"type\":\"object\",\"properties\":{\"report_fragment_id\":{\"type\":\"string\"}},\"required\":[\"report_fragment_id\"],\"additionalProperties\":false}");
HERO_LATTICE_MCP_TOOL("hero.lattice.list_report_schemas", "List distinct runtime report schemas available for hashimyei_cursor (canonical_path alias accepted)", "{\"type\":\"object\",\"properties\":{\"canonical_path\":{\"type\":\"string\"},\"hashimyei_cursor\":{\"type\":\"string\"}},\"anyOf\":[{\"required\":[\"canonical_path\"]},{\"required\":[\"hashimyei_cursor\"]}]}");
HERO_LATTICE_MCP_TOOL("hero.lattice.get_report_lls", "Join .lls report fragments for hashimyei_cursor (canonical_path alias accepted); supports intersection_cursor (hashimyei_cursor|wave_cursor) where wave_cursor may be packed integer or <run>.<epoch>,<batch>; tsi.source joins source-runtime + data-analytics when present and includes cursor headers with readable views", "{\"type\":\"object\",\"properties\":{\"canonical_path\":{\"type\":\"string\"},\"hashimyei_cursor\":{\"type\":\"string\"},\"intersection_cursor\":{\"type\":\"string\"},\"run_id\":{\"type\":\"string\"},\"schema\":{\"type\":\"string\"},\"wave_cursor\":{\"type\":\"string\"},\"wave_cursor_mask\":{\"type\":\"string\"},\"limit\":{\"type\":\"integer\"},\"offset\":{\"type\":\"integer\"},\"newest_first\":{\"type\":\"boolean\"}},\"anyOf\":[{\"required\":[\"canonical_path\"]},{\"required\":[\"hashimyei_cursor\"]},{\"required\":[\"intersection_cursor\"]}]}");
HERO_LATTICE_MCP_TOOL("hero.lattice.reset_catalog", "Reset lattice catalog file and optionally reingest runtime report fragment rows", "{\"type\":\"object\",\"properties\":{\"reingest_report_fragments\":{\"type\":\"boolean\"}}}");
