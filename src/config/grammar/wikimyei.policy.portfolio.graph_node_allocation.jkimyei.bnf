<instruction> ::= "TRAINING" [<whitespace>] "{" <line_end> {<assignment>} [<whitespace>] "}" [<whitespace>] ";" [<line_end>] ;
<assignment>  ::= [<whitespace>] <key> [<whitespace>] "=" [<whitespace>] <value> [<whitespace>] ";" <line_end> ;
<key>         ::= "VERSION" | "TRAINING_ID" | "TASK" | "COMPONENT_ASSEMBLY_ID" | "ACTION_DISTRIBUTION" | "OPTIMIZER" | "LEARNING_RATE" | "MAX_STEPS" | "BATCH_SIZE" | "GRAD_CLIP_NORM" | "CHECKPOINT_EVERY" | "REPORT_EVERY" | "VALIDATION_EVERY" | "SEED" | "FREEZE_REPRESENTATION" | "INPUT_REPRESENTATION_CHECKPOINT" | "INPUT_MDN_CHECKPOINT" | "ALLOW_UNTRAINED_REPRESENTATION" | "TRAINING_SCHEDULE_MODE" | "REQUIRE_CAUSAL_SCHEDULE" | "PPO_EXECUTION_ALLOWED" | "CHECKPOINT_KIND" ;
<value>       ::= {<value_char>} ;
<value_char>  ::= <letter> | <digit> | "_" | "." | "-" | "+" | "/" ;
<line_end>    ::= [<whitespace>] <break_block> ;
<break_block> ::= {<newline>} ;
<whitespace>  ::= {<empty>} ;
