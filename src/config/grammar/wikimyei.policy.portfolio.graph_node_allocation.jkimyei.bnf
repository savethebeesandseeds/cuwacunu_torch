<instruction> ::= "TRAINING" [<whitespace>] "{" <line_end> {<assignment>} [<whitespace>] "}" [<whitespace>] ";" [<line_end>] ;
<assignment>  ::= [<whitespace>] <key> [<whitespace>] "=" [<whitespace>] <value> [<whitespace>] ";" <line_end> ;
<key>         ::= "TRAINING_ID" | "TASK" | "LEARNING_RATE" | "MAX_STEPS" | "BATCH_SIZE" | "GRAD_CLIP_NORM" | "PPO_GAMMA" | "PPO_GAE_LAMBDA" | "PPO_CLIP_EPSILON" | "PPO_TARGET_KL" | "PPO_ENTROPY_COEFF" | "PPO_VALUE_LOSS_COEFF" | "PPO_EPOCHS_PER_ROLLOUT" | "CHECKPOINT_EVERY" | "REPORT_EVERY" | "SEED" ;
<value>       ::= {<value_char>} ;
<value_char>  ::= <letter> | <digit> | "_" | "." | "-" | "+" | "/" ;
<line_end>    ::= [<whitespace>] <break_block> ;
<break_block> ::= {<newline>} ;
<whitespace>  ::= {<empty>} ;
