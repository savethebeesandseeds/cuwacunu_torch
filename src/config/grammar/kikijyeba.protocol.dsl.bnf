<instruction> ::= "PROTOCOL" [<whitespace>] "{" <line_end> {<assignment>} [<whitespace>] "}" [<whitespace>] ";" [<line_end>] ;
<assignment>  ::= [<whitespace>] <key> [<whitespace>] "=" [<whitespace>] <value> [<whitespace>] ";" [<line_end>] ;
<key>         ::= "PROTOCOL_ID" | "PROTOCOL_KIND" | "GRAPH_TOPOLOGY" | "NODELIFT" | "REPRESENTATION" | "INFERENCE" | "OBSERVER" | "ALLOCATION_POLICY" | "POLICY_COMPONENT" | "REPRESENTATION_CONTRACT" | "PROTOCOL_STATUS" | "SUCCESSOR_PROTOCOL" | "PROTOCOL_WARNING" ;
<value>       ::= { ? any character except ';' ? } ;
<whitespace>  ::= " " | "\t" | "\r" | "\n" ;
<line_end>    ::= "\n" | "\r\n" ;
