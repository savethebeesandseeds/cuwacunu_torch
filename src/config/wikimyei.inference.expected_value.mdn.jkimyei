/*
  Canonical long train-core policy for cwu_02v channel-context MDN recovery.

  Model-state input fields are omitted from this static profile. Marshal
  resolves proof-clean latest_satisfying checkpoint hints into a
  runtime_handoff, and Runtime passes concrete paths to cuwacunu_exec as
  launch-time overrides.
*/
TRAINING {
  TRAINING_ID = real_channel_mdn_train_core_v1;
  TASK = mdn_expected_value_inference;
  LEARNING_RATE = 0.001;
  MAX_STEPS = 3500;
  BATCH_SIZE = 64;
  GRAD_CLIP_NORM = 5.0;
  CHECKPOINT_EVERY = 50;
  REPORT_EVERY = 10;
  SEED = 31;
  MDN_EDGE_RETURN_AUXILIARY_LOSS_WEIGHT = 0.0;
  MDN_EDGE_RETURN_AUXILIARY_DIRECTION_WEIGHT = 0.0;
  MDN_EDGE_RETURN_AUXILIARY_RANK_WEIGHT = 0.0;
  MDN_EDGE_RETURN_AUXILIARY_HUBER_BETA = 0.01;
  MDN_EDGE_RETURN_AUXILIARY_LOGIT_SCALE = 50.0;
  MDN_DIRECT_EDGE_RETURN_READOUT_ENABLED = true;
  MDN_DIRECT_EDGE_RETURN_READOUT_LOSS_WEIGHT = 100.0;
  MDN_DIRECT_EDGE_RETURN_READOUT_DIRECTION_WEIGHT = 5.0;
  MDN_DIRECT_EDGE_RETURN_READOUT_RANK_WEIGHT = 5.0;
  MDN_DIRECT_EDGE_RETURN_READOUT_HUBER_BETA = 0.01;
  MDN_DIRECT_EDGE_RETURN_READOUT_LOGIT_SCALE = 50.0;
};
