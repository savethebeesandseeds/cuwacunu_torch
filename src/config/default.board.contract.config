[SPECS]
    vicreg_config_filename              = /cuwacunu/src/config/instructions/tsi.wikimyei.representation.vicreg.dsl
    # optional neutral network-design payload (decoder is framework-agnostic)
    vicreg_network_design_filename      = /cuwacunu/src/config/instructions/tsi.wikimyei.representation.vicreg.network_design.dsl
    value_estimation_config_filename    = /cuwacunu/src/config/instructions/tsi.wikimyei.inference.mdn.value_estimation.dsl
    transfer_matrix_evaluation_config_filename = /cuwacunu/src/config/instructions/tsi.probe.representation.transfer_matrix_evaluation.dsl
[DSL]
    observation_sources_dsl_filename    = /cuwacunu/src/config/instructions/tsi.source.dataloader.sources.dsl
    observation_channels_dsl_filename   = /cuwacunu/src/config/instructions/tsi.source.dataloader.channels.dsl
    jkimyei_specs_dsl_filename          = /cuwacunu/src/config/instructions/jkimyei.representation.vicreg.dsl
    # optional csv list for additional per-component jkimyei DSL files
    # jkimyei_specs_extra_dsl_filenames = /cuwacunu/src/config/instructions/jkimyei.inference.mdn.dsl
    tsiemene_circuit_dsl_filename       = /cuwacunu/src/config/instructions/iitepi.contract.circuit.example.dsl
