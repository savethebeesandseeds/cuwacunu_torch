  ENCODING_DIM = 8;
  FEATURE_HIDDEN_DIM = 32;
  TEMPORAL_DEPTH = 1;
  RECENCY_DECAY = 0.85;
  VICREG_PROJECTOR_DIM = 16;
  VICREG_PROJECTOR_HIDDEN_DIM = 32;
