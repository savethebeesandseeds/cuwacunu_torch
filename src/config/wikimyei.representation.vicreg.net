/*
  wikimyei.representation.vicreg.net
  ==========================================
  Neural architecture for the channel-preserving VICReg representation path.
*/
VICREG_NET {
  ENCODING_DIM = 32;
  FEATURE_HIDDEN_DIM = 128;
  TEMPORAL_DEPTH = 2;
  RECENCY_DECAY = 0.90;
  VICREG_PROJECTOR_DIM = 64;
  VICREG_PROJECTOR_HIDDEN_DIM = 128;
  VICREG_PROJECTOR_DEPTH = 2;
  VICREG_INVARIANCE_WEIGHT = 25.0;
  VICREG_VARIANCE_WEIGHT = 25.0;
  VICREG_COVARIANCE_WEIGHT = 1.0;
  VICREG_VARIANCE_FLOOR = 1.0;
  VICREG_EPS = 0.0001;
  GLOBAL_AUX_WEIGHT = 0.0;
  MIN_VALID_ROWS = 2;
  SKIP_NON_FINITE_LOSS = true;
  JITTER_STD = 0.01;
  FEATURE_DROPOUT_PROB = 0.0;
  HISTORY_DROPOUT_PROB = 0.0;
};
