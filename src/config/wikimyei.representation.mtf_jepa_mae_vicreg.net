MTF_JEPA_MAE_VICREG_NET {
  D_MODEL = 32;
  LATENT_DIM = 32;
  PROJECTOR_DIM = 64;
  PREDICTOR_HIDDEN_DIM = 64;
  NUM_ENCODER_LAYERS = 2;
  NUM_PREDICTOR_LAYERS = 2;
  NUM_DECODER_LAYERS = 1;
  NUM_HEADS = 4;
  DROPOUT = 0.10;

  TIME_SCALES = 8,16,32,64;
  SCALE_STRIDES = 4,8,16,32;
  USE_FREQUENCY_TOKENS = true;
  FREQUENCY_NUM_BINS = 16;
  FREQUENCY_LOG_MAGNITUDE = true;

  MASK_RATIO_TIME = 0.50;
  MASK_RATIO_FREQUENCY = 0.30;
  MASK_RATIO_CHANNEL = 0.10;
  MIN_CONTEXT_RATIO = 0.25;

  LAMBDA_JEPA = 1.0;
  LAMBDA_MAE = 0.25;
  LAMBDA_TF_ALIGN = 0.10;
  LAMBDA_VICREG = 0.05;
  LAMBDA_GLOBAL_VICREG = 1.0;
  LAMBDA_CHANNEL_VICREG = 1.0;

  VICREG_SIM_WEIGHT = 25.0;
  VICREG_VAR_WEIGHT = 25.0;
  VICREG_COV_WEIGHT = 1.0;
  VICREG_VARIANCE_FLOOR = 1.0;
  VICREG_VARIANCE_EPSILON = 0.0001;

  TARGET_EMA_TAU = 0.996;
  USE_TARGET_EMA = true;
  STOP_GRADIENT_TARGET = true;
  RETURN_DIAGNOSTICS = true;

  USE_MAE_DECODER = true;
  USE_JEPA_LOSS = true;
  USE_TF_ALIGN_LOSS = true;
  USE_VICREG_LOSS = true;
  USE_GLOBAL_VICREG = true;
  USE_CHANNEL_VICREG = false;
  USE_RAW_RECONSTRUCTION_TARGETS = true;
  STRICT_FINITE_LOSS = true;
  COUPLE_TIME_FREQUENCY_MASKS = true;
  MASK_SAME_WINDOW_ACROSS_DOMAINS = true;
  MASK_SAME_CHANNEL_BLOCK = false;
  MAX_CONTEXT_TARGET_TIME_OVERLAP = 0.50;
};
