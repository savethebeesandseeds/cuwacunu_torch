/*
  wikimyei.representation.vicreg.jkimyei
  ==============================================
  Train-core policy for channel-preserving VICReg pretraining.
*/
TRAINING {
  TRAINING_ID = real_vicreg_train_core_v1;
  TASK = vicreg_representation;
  LEARNING_RATE = 0.001;
  MAX_STEPS = 250;
  BATCH_SIZE = 64;
  GRAD_CLIP_NORM = 5.0;
  CHECKPOINT_EVERY = 50;
  REPORT_EVERY = 10;
  SEED = 17;
};
