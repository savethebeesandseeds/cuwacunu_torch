[FIELD OBJECTIVE.CAMPAIGN]
key = vicreg.solo campaign bundle
scope = objective root
type = bundled experiment surface
required = true
default = src/config/instructions/objectives/vicreg.solo/iitepi.campaign.dsl
range = one active objective campaign
allowed = objective-local campaign + wave + contract set
nuance = objective owns the train/eval bind plan and now freezes the selected big-span observation profile locally. Unchanged sources stay in ../../defaults; both evaluation sidecars now resolve from the shared defaults bundle instead of carrying redundant objective-local copies

[FIELD OBJECTIVE.OBS_PROFILE]
key = big_span_v1 observation profile
scope = vicreg.solo objective root
type = frozen observation surface
required = true
default = src/config/instructions/objectives/vicreg.solo/tsi.source.dataloader.channels.dsl
range = one objective-owned channel table
allowed = active rows 1w,3d,1d with docking C=3,T=30,D=9
nuance = vicreg.solo is currently the long-horizon representation study. Minute-resolution expansion is intentionally out of scope for this objective so architecture and jkimyei comparisons remain interpretable

[FIELD OBJECTIVE.FIXED_AXES]
key = fixed axes
scope = vicreg.solo research loop
type = design guardrail
required = true
default = observation profile + train/eval date split
range = one active baseline definition
allowed = channels, docking boundary, train split, eval split
nuance = iterate architecture and jkimyei only while the observation profile is frozen. Changing active channels or docking dimensions starts a different representation family and should not be treated as a minor ablation

[FIELD OBJECTIVE.TUNABLE_AXES]
key = tunable axes
scope = vicreg.solo research loop
type = design search surface
required = true
default = internal network widths + projector topology/options + jkimyei profile
range = one or more candidate sweeps
allowed = private network dimensions, network depth, projector dims, projector norm/activation/bias policy, optimizer/loss/augmentation profiles
nuance = compare one axis at a time. Promote only candidates that improve holdout report evidence without destabilizing training or exploding runtime cost

[FIELD OBJECTIVE.ARCH_SWEEP]
key = architecture sweep surface
scope = vicreg.solo objective root
type = contract-variant family
required = true
default = baseline + small + wide + deep
range = imported contract variants with frozen public dock
allowed = iitepi.contract.base.dsl,iitepi.contract.small.dsl,iitepi.contract.wide.dsl,iitepi.contract.deep.dsl
nuance = network-design sweeps are contract-driven in the current runtime because bind-local __variables only resolve inside the wave graph. Each candidate keeps the same observation dock and embedding width while changing only private VICReg encoder/projector architecture and projector option policy

[FIELD OBJECTIVE.DEFAULT_RUN_PLAN]
key = RUN default plan
scope = vicreg.solo campaign
type = ordered bind sequence
required = true
default = bind_train_vicreg_primary,bind_eval_vicreg_payload
range = one or more RUN lines
allowed = declared BIND ids
nuance = when this campaign bundle is selected, hero.runtime.start_campaign(campaign_dsl_path=...) executes the RUN list sequentially; hero.runtime.start_campaign(binding_id=...) ignores the RUN list for that launch and runs only the selected BIND

