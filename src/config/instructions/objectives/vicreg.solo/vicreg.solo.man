[FIELD WAVE.train_vicreg_primary]
key = train_vicreg_primary
scope = vicreg.solo wave catalog
type = train wave with bind-controlled debug
required = true
default = EPOCHS=1,BATCH_SIZE=64,MAX_BATCHES_PER_EPOCH=4000
