/*
  default.super.objective.dsl
  ===========================
  Machine anchor for a Super Hero loop. This file chooses the campaign bundle
  and the human-authored supervision prompt for one objective.
  Optional:
    loop_id:str = some.stable.loop.id
*/
campaign_dsl_path:path = default.iitepi.campaign.dsl
objective_prompt_path:path = default.super.objective.md
objective_name:str = default.super.objective
