[GUI]
    iinuji_logs_buffer_capacity = 6000
    iinuji_logs_show_date = false
    iinuji_logs_show_thread = false
    iinuji_logs_show_metadata = true
    iinuji_logs_metadata_filter = any
    iinuji_logs_show_color = true
    iinuji_logs_auto_follow = true
    iinuji_logs_mouse_capture = true
    iinuji_loading_logo_path = ../resources/waajacamaya_hello.png
    iinuji_closing_logo_path = ../resources/waajacamaya.png
    iinuji_home_animation_path = ../resources/waajacamaya.apng
