[GENERAL]
    exchange_type                  = TEST
    absolute_base_symbol           = USDT
    iinuji_logs_buffer_capacity    = 6000   # max in-memory entries shown in F8 logs
    iinuji_logs_show_date          = true   # F8 default: show timestamp
    iinuji_logs_show_thread        = true   # F8 default: show thread id
    iinuji_logs_show_metadata      = true   # F8 default: append metadata fields when available
    iinuji_logs_metadata_filter    = any    # any|any_meta|function|path|callsite
    iinuji_logs_show_color         = true   # F8 default: severity line emphasis
    iinuji_logs_auto_follow        = true   # F8 default: jump to newest on new logs
    iinuji_logs_mouse_capture      = true   # F8 default: capture mouse vs terminal copy/select
    torch_seed                     = 42
    board_config_filename          = /cuwacunu/src/config/instructions/default.iitepi.board.dsl
    board_binding_id               = bind_train_vicreg
    hashimyei_store_root           = /cuwacunu/.hashimyei
    hashimyei_metadata_secret      = CHANGE_ME_HASHIMYEI_METADATA_SECRET

[BNF]
    iitepi_board_grammar_filename                 = /cuwacunu/src/config/bnf/iitepi.board.bnf
    iitepi_wave_grammar_filename                  = /cuwacunu/src/config/bnf/iitepi.wave.bnf
    network_design_grammar_filename               = /cuwacunu/src/config/bnf/network_design.bnf
    vicreg_grammar_filename                       = /cuwacunu/src/config/bnf/latent_lineage_state.bnf
    value_estimation_grammar_filename             = /cuwacunu/src/config/bnf/latent_lineage_state.bnf
    wikimyei_inference_transfer_matrix_evaluation_grammar_filename = /cuwacunu/src/config/bnf/latent_lineage_state.bnf
    observation_sources_grammar_filename          = /cuwacunu/src/config/bnf/tsi.source.dataloader.sources.bnf
    observation_channels_grammar_filename         = /cuwacunu/src/config/bnf/tsi.source.dataloader.channels.bnf
    jkimyei_specs_grammar_filename                = /cuwacunu/src/config/bnf/jkimyei.bnf
    tsiemene_circuit_grammar_filename             = /cuwacunu/src/config/bnf/iitepi.contract.circuit.bnf
    canonical_path_grammar_filename               = /cuwacunu/src/config/bnf/canonical_path.bnf

[TSI_RUNTIME]
    runtime_trace_level            = 1        # 0=Off, 1=Step, 2=Verbose
    runtime_max_queue_size         = 10000    # 0=unbounded; >0 halts runtime on backpressure

[REAL_EXCHANGE]
    Ed25519_pkey                   = /cuwacunu/src/config/secrets/real/ed25519key.pem
    EXCHANGE_api_filename          = /cuwacunu/src/config/secrets/real/exchange.key
    websocket_url                  = wss://ws-api.binance.com:443/ws-api/v3

[TEST_EXCHANGE]
    Ed25519_pkey                   = /cuwacunu/src/config/secrets/test/ed25519key.pem
    EXCHANGE_api_filename          = /cuwacunu/src/config/secrets/test/exchange.key
    websocket_url                  = wss://testnet.binance.vision/ws-api/v3

[REAL_HERO]
    mode                           = openai
    transport                      = curl
    OPENAI_api_filename            = /cuwacunu/src/config/secrets/real/openai.key   # secured key file (AEAD envelope)
    endpoint                       = https://api.openai.com/v1/responses
    config_hero_dsl_filename       = /cuwacunu/src/config/instructions/default.hero.config.dsl
    hashimyei_hero_dsl_filename    = /cuwacunu/src/config/instructions/default.hero.hashimyei.dsl
    lattice_hero_dsl_filename         = /cuwacunu/src/config/instructions/default.hero.lattice.dsl
