[GENERAL]
    exchange_type                  = TEST
    absolute_base_symbol           = USDT
    iinuji_logs_buffer_capacity    = 6000   # max in-memory entries shown in F8 logs
    torch_seed                     = 42
    board_config_filename          = /cuwacunu/src/config/default.board.config
    board_binding_id               = bind_train_vicreg
    hashimyei_store_root           = /cuwacunu/data/hashimyei
    hashimyei_metadata_secret      = CHANGE_ME_HASHIMYEI_METADATA_SECRET

[BNF]
    iitepi_board_grammar_filename                 = /cuwacunu/src/config/bnf/iitepi.board.bnf
    iitepi_wave_grammar_filename                  = /cuwacunu/src/config/bnf/iitepi.wave.bnf
    network_design_grammar_filename               = /cuwacunu/src/config/bnf/network_design.bnf
    vicreg_grammar_filename                       = /cuwacunu/src/config/bnf/key_value.bnf
    value_estimation_grammar_filename             = /cuwacunu/src/config/bnf/key_value.bnf
    transfer_matrix_evaluation_grammar_filename   = /cuwacunu/src/config/bnf/key_value.bnf
    observation_sources_grammar_filename          = /cuwacunu/src/config/bnf/tsi.source.dataloader.sources.bnf
    observation_channels_grammar_filename         = /cuwacunu/src/config/bnf/tsi.source.dataloader.channels.bnf
    jkimyei_specs_grammar_filename                = /cuwacunu/src/config/bnf/jkimyei.bnf
    tsiemene_circuit_grammar_filename             = /cuwacunu/src/config/bnf/iitepi.contract.circuit.bnf
    canonical_path_grammar_filename               = /cuwacunu/src/config/bnf/canonical_path.bnf

[DATA_LOADER]
    # Legacy compatibility section.
    # Board-bound runtime now uses WAVE.SOURCE fields and sources.dsl CSV_POLICY.
    dataloader_workers             = 0
    dataloader_force_rebuild_cache = true
    dataloader_range_warn_batches  = 256
    dataloader_csv_bootstrap_deltas = 64
    dataloader_csv_step_abs_tol    = 1e-8
    dataloader_csv_step_rel_tol    = 1e-10

[TSI_RUNTIME]
    runtime_trace_level            = 1        # 0=Off, 1=Step, 2=Verbose
    runtime_max_queue_size         = 10000    # 0=unbounded; >0 halts runtime on backpressure

[REAL_EXCHANGE]
    Ed25519_pkey                   = /cuwacunu/src/config/secrets/real/ed25519key.pem
    EXCHANGE_api_filename          = /cuwacunu/src/config/secrets/real/exchange.key
    websocket_url                  = wss://ws-api.binance.com:443/ws-api/v3

[TEST_EXCHANGE]
    Ed25519_pkey                   = /cuwacunu/src/config/secrets/test/ed25519key.pem
    EXCHANGE_api_filename          = /cuwacunu/src/config/secrets/test/exchange.key
    websocket_url                  = wss://testnet.binance.vision/ws-api/v3
