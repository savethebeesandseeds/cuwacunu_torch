RUNTIME_SECTION = WIKIMYEI_EVALUATION_TRANSFER_MATRIX_EVALUATION
RUNTIME_ACTIVE_KEYS = check_temporal_order,validate_vicreg_out,report_shapes,summary_every_steps,mdn_target_dims,mdn_mixture_comps,mdn_features_hidden,mdn_residual_depth,optimizer_lr,optimizer_weight_decay,optimizer_beta1,optimizer_beta2,optimizer_eps,grad_clip,nll_eps,nll_sigma_min,nll_sigma_max,anchor_train_ratio,anchor_val_ratio,anchor_test_ratio,prequential_blocks,linear_ridge_lambda,gaussian_var_min,control_shuffle_block,control_shuffle_seed
