[FIELD summary_every_steps]
key = summary_every_steps
scope = WIKIMYEI_EVALUATION_TRANSFER_MATRIX_EVALUATION
type = int
required = false
default = 256
range = >= 0 (clamped)
allowed = integer
nuance = controls cadence for step-time meta summaries while full transfer-matrix reports are emitted at run_end.

[FIELD mdn_target_dims]
key = mdn_target_dims
scope = WIKIMYEI_EVALUATION_TRANSFER_MATRIX_EVALUATION
type = arr[int]
required = false
default = all active observation feature dims
range = each entry must satisfy 0 <= dim < D
allowed = integer list
nuance = optional probe-local override for the future feature indices evaluated by the transfer-matrix probe. When omitted, the evaluator derives the full active feature set from the observation profile. Contract-scoped __future_target_dims can coordinate this with EXPECTED_VALUE.target_dims without creating any runtime dependency. Deprecated alias: target_dims.
