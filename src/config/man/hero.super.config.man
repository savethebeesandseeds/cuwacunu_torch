MAN_SPEC_VERSION = 1

[META]
MAN_ID = hero.super.config
TARGET_DSL = src/config/instructions/defaults/default.hero.super.dsl
TARGET_BNF = src/config/bnf/latent_lineage_state.authored.bnf
PRIMARY_DECODER = src/impl/camahjucunu/dsl/latent_lineage_state/latent_lineage_state.cpp
PRIMARY_VALIDATORS = src/main/hero/hero_super_mcp.cpp

[FIELD runtime_hero_binary]
key = runtime_hero_binary
scope = hero super defaults
type = path_or_command
required = true
default = /cuwacunu/.build/hero/hero_runtime_mcp
range = executable path or PATH-resolved command name
allowed = absolute_or_relative path or bare command token
nuance = Runtime Hero MCP binary that Super Hero uses to launch, inspect, and stop campaigns

[FIELD config_hero_binary]
key = config_hero_binary
scope = hero super defaults
type = path_or_command
required = true
default = /cuwacunu/.build/hero/hero_config_mcp
range = executable path or PATH-resolved command name
allowed = absolute_or_relative path or bare command token
nuance = Config Hero MCP binary attached to Codex planning turns for bounded truth-source objective/default file mutation plus audited backups

[FIELD lattice_hero_binary]
key = lattice_hero_binary
scope = hero super defaults
type = path_or_command
required = true
default = /cuwacunu/.build/hero/hero_lattice_mcp
range = executable path or PATH-resolved command name
allowed = absolute_or_relative path or bare command token
nuance = Lattice Hero MCP binary attached to Codex planning turns for fact/view inspection

[FIELD human_hero_binary]
key = human_hero_binary
scope = hero super defaults
type = path_or_command
required = true
default = /cuwacunu/.build/hero/hero_human_mcp
range = executable path or PATH-resolved command name
allowed = absolute_or_relative path or bare command token
nuance = Human Hero MCP binary Super Hero invokes when a planning turn escalates and must materialize or refresh the operator-facing escalation artifact

[FIELD human_operator_identities]
key = human_operator_identities
scope = hero super defaults
type = path
required = true
default = ../../secrets/real/human_operator_identities
range = readable operator identity map
allowed = absolute path or path resolved relative to default.hero.super.dsl
nuance = operator identities file Super Hero uses to bind Human Hero operator_id values to OpenSSH ssh-ed25519 public keys before applying a signed human resolution

[FIELD config_scope_root]
key = config_scope_root
scope = hero super defaults
type = path
required = true
default = ../..
range = writable config scope root
allowed = absolute path or path resolved relative to default.hero.super.dsl
nuance = config root Super Hero bakes into its loop-local Config Hero policy instead of peeking into Config Hero defaults; the generated policy writes truth-source objective/default backups outside runtime state

[FIELD super_codex_binary]
key = super_codex_binary
scope = hero super defaults
type = path_or_command
required = true
default = codex
range = executable path or PATH-resolved command name
allowed = absolute_or_relative path or bare command token
nuance = Codex command used by Super Hero at each autonomous planning turn

[FIELD tail_default_lines]
key = tail_default_lines
scope = hero super defaults
type = uint
required = true
default = 120
range = [1,+inf)
allowed = unsigned integer
nuance = default log/trace tail size used when Super Hero assembles turn context evidence for Codex

[FIELD poll_interval_ms]
key = poll_interval_ms
scope = hero super defaults
type = uint
required = true
default = 1000
range = [100,+inf)
allowed = unsigned integer
nuance = detached loop-runner polling interval while waiting for the active Runtime campaign to reach a terminal state

[FIELD super_codex_timeout_sec]
key = super_codex_timeout_sec
scope = hero super defaults
type = uint
required = true
default = 900
range = [1,+inf)
allowed = unsigned integer
nuance = wall-clock timeout for one Codex planning call within a Super Hero loop

[FIELD super_max_review_turns]
key = super_max_review_turns
scope = hero super defaults
type = uint
required = true
default = 8
range = [1,+inf)
allowed = unsigned integer
nuance = hard upper bound on Codex planning turns within one Super Hero loop before the loop ends as exhausted; this budget includes the initial bootstrap turn

[FIELD super_max_campaign_launches]
key = super_max_campaign_launches
scope = hero super defaults
type = uint
required = true
default = 8
range = [1,+inf)
allowed = unsigned integer
nuance = hard upper bound on Runtime campaign launches within one Super Hero loop before the loop ends as exhausted
