MAN_SPEC_VERSION = 1

[META]
MAN_ID = tsi.wikimyei.inference.mdn.expected_value
TARGET_DSL = src/config/instructions/defaults/default.tsi.wikimyei.inference.mdn.expected_value.dsl
TARGET_BNF = src/config/bnf/latent_lineage_state.authored.bnf
PRIMARY_DECODER = latent_lineage_state decoder + contract module validator
PRIMARY_VALIDATORS = src/impl/iitepi/contract_space_t.cpp,src/impl/wikimyei/inference/expected_value/expected_value.cpp,src/impl/wikimyei/inference/mdn/mixture_density_network.cpp

[FIELD model_path]
key = model_path
scope = EXPECTED_VALUE
type = string path
required = true
default = none
range = non-empty path string
allowed = path text
nuance = checkpoint loader/saver enforces strict v2 metadata contract

[FIELD verbose_train]
key = verbose_train
scope = EXPECTED_VALUE
type = bool
required = true
default = none
range = bool token
allowed = contract bool parse tokens
nuance = runtime verbosity toggle

[FIELD telemetry_every]
key = telemetry_every
scope = EXPECTED_VALUE
type = int
required = true
default = none
range = integer (recommended >= -1)
allowed = integer
nuance = config key is required by validator; current ExpectedValue ctor does not auto-wire this key into telemetry cadence without explicit setter usage

[FIELD target_dims]
key = target_dims
scope = EXPECTED_VALUE
type = arr[int]
required = true
default = none
range = non-empty; each dim in [0,D)
allowed = comma-separated integers
nuance = runtime selects the target Y columns for the MDN; the exposed statistic is E[Y|X], so these indices define what Y means

[FIELD target_weights]
key = target_weights
scope = EXPECTED_VALUE
type = arr[float]
required = true
default = none
range = non-empty
allowed = comma-separated floats
nuance = runtime requires size(target_weights) == size(target_dims) when non-empty

[FIELD mixture_comps]
key = mixture_comps
scope = EXPECTED_VALUE
type = int
required = true
default = none
range = > 0
allowed = integer
nuance = number of mixture components used to model the predictive distribution p(Y|X); enforced by MDN model constructor

[FIELD features_hidden]
key = features_hidden
scope = EXPECTED_VALUE
type = int
required = true
default = none
range = > 0
allowed = integer
nuance = enforced by MDN model constructor

[FIELD residual_depth]
key = residual_depth
scope = EXPECTED_VALUE
type = int
required = true
default = none
range = >= 0
allowed = integer
nuance = enforced by MDN model constructor

[FIELD grad_clip]
key = grad_clip
scope = EXPECTED_VALUE
type = float
required = true
default = none
range = real
allowed = float
nuance = clipping is applied only when grad_clip > 0

[FIELD optimizer_threshold_reset]
key = optimizer_threshold_reset
scope = EXPECTED_VALUE
type = int
required = true
default = none
range = integer
allowed = integer
nuance = reset hook is applied only when value >= 0; negative means disabled

[FIELD dtype]
key = dtype
scope = EXPECTED_VALUE
type = dtype token
required = true
default = none
range = known dtype tokens
allowed = bool,int8,int16,int32,int64,float16,half,f16,float32,float,f32,float64,double,f64 and torch::/at::/k-prefixed variants
nuance = invalid token fails contract validation

[FIELD device]
key = device
scope = EXPECTED_VALUE
type = device token
required = true
default = none
range = cpu or cuda-class token
allowed = cpu,cuda,gpu,cuda:<n>,gpu:<n>,torch::kcpu,torch::kcuda,kcpu,kcuda
nuance = CUDA unavailability or runtime probe failure triggers CPU fallback warning

[RULE UNKNOWN_KEYS]
id = UNKNOWN_KEYS
applies_to = EXPECTED_VALUE module section
severity = error
when = key not in allow-list
message = unknown key in module config is rejected
