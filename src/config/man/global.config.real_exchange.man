MAN_SPEC_VERSION = 1

[META]
MAN_ID = global.config.real_exchange
TARGET_DSL = src/config/.config
TARGET_BNF = src/impl/iitepi/config_space_t.cpp (INI-like parser)
PRIMARY_DECODER = src/impl/iitepi/config_space_t.cpp
PRIMARY_VALIDATORS = src/impl/iitepi/config_space_t.cpp

[FIELD REAL_EXCHANGE.Ed25519_pkey]
key = Ed25519_pkey
scope = REAL_EXCHANGE section
type = path
required = true
default = /cuwacunu/src/config/secrets/real/ed25519key.pem
range = non-empty path
allowed = absolute_or_relative path
nuance = Ed25519 private key used for real exchange request signing

[FIELD REAL_EXCHANGE.EXCHANGE_api_filename]
key = EXCHANGE_api_filename
scope = REAL_EXCHANGE section
type = path
required = true
default = /cuwacunu/src/config/secrets/real/exchange.key
range = non-empty path
allowed = absolute_or_relative path
nuance = path to real exchange API key material; store the secret in the referenced file, not inline in .config

[FIELD REAL_EXCHANGE.websocket_url]
key = websocket_url
scope = REAL_EXCHANGE section
type = string
required = true
default = wss://ws-api.binance.com:443/ws-api/v3
range = non-empty URL
allowed = wss URL
nuance = websocket endpoint for real exchange traffic when GENERAL.exchange_type=REAL
