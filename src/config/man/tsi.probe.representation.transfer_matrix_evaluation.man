MAN_SPEC_VERSION = 1

[META]
MAN_ID = tsi.probe.representation.transfer_matrix_evaluation
TARGET_DSL = src/config/instructions/tsi.probe.representation.transfer_matrix_evaluation.dsl
TARGET_BNF = src/config/bnf/key_value.bnf
PRIMARY_DECODER = key_value decoder + contract module validator
PRIMARY_VALIDATORS = src/impl/iitepi/contract_space_t.cpp,src/include/tsiemene/tsi.probe.representation.transfer_matrix_evaluation.h

[FIELD check_temporal_order]
key = check_temporal_order
scope = TRANSFER_MATRIX_EVALUATION
type = bool
required = false
default = true
range = bool token
allowed = contract bool parse tokens
nuance = enables temporal overlap guard between past and future key ranges

[FIELD validate_vicreg_out]
key = validate_vicreg_out
scope = TRANSFER_MATRIX_EVALUATION
type = bool
required = false
default = true
range = bool token
allowed = contract bool parse tokens
nuance = enforces cargo validation stage checks before probe training

[FIELD report_shapes]
key = report_shapes
scope = TRANSFER_MATRIX_EVALUATION
type = bool
required = false
default = false
range = bool token
allowed = contract bool parse tokens
nuance = shape diagnostics emitted only on anomalies

[FIELD reset_hashimyei_on_start]
key = reset_hashimyei_on_start
scope = TRANSFER_MATRIX_EVALUATION
type = bool
required = false
default = false
range = bool token
allowed = contract bool parse tokens
nuance = controls persisted history reset behavior

[FIELD mdn_mixture_comps]
key = mdn_mixture_comps
scope = TRANSFER_MATRIX_EVALUATION
type = int
required = false
default = 1
range = >= 1 (clamped)
allowed = integer
nuance = values <=0 are replaced by 1

[FIELD mdn_features_hidden]
key = mdn_features_hidden
scope = TRANSFER_MATRIX_EVALUATION
type = int
required = false
default = 16
range = >= 1 (clamped)
allowed = integer
nuance = values <=0 are replaced by 16

[FIELD mdn_residual_depth]
key = mdn_residual_depth
scope = TRANSFER_MATRIX_EVALUATION
type = int
required = false
default = 0
range = >= 0 (clamped)
allowed = integer
nuance = negative values are replaced by 0

[FIELD mdn_target_dims]
key = mdn_target_dims
scope = TRANSFER_MATRIX_EVALUATION
type = arr[int]
required = false
default = empty (fallback to VALUE_ESTIMATION.target_dims)
range = if empty fallback; otherwise non-empty runtime requirement
allowed = comma-separated ints
nuance = final model target dims come from mdn_target_dims if provided else VALUE_ESTIMATION.target_dims

[FIELD optimizer_lr]
key = optimizer_lr
scope = TRANSFER_MATRIX_EVALUATION
type = float
required = false
default = 1e-3
range = > 0 (fallback to default)
allowed = float
nuance = non-positive values are replaced by default

[FIELD optimizer_weight_decay]
key = optimizer_weight_decay
scope = TRANSFER_MATRIX_EVALUATION
type = float
required = false
default = 1e-2
range = real
allowed = float
nuance = consumed directly by AdamW options

[FIELD optimizer_beta1]
key = optimizer_beta1
scope = TRANSFER_MATRIX_EVALUATION
type = float
required = false
default = 0.9
range = [0,1) else fallback
allowed = float
nuance = values outside [0,1) are reset to default 0.9

[FIELD optimizer_beta2]
key = optimizer_beta2
scope = TRANSFER_MATRIX_EVALUATION
type = float
required = false
default = 0.999
range = [0,1) else fallback
allowed = float
nuance = values outside [0,1) are reset to default 0.999

[FIELD optimizer_eps]
key = optimizer_eps
scope = TRANSFER_MATRIX_EVALUATION
type = float
required = false
default = 1e-8
range = > 0 (fallback to default)
allowed = float
nuance = non-positive values are replaced by default

[FIELD grad_clip]
key = grad_clip
scope = TRANSFER_MATRIX_EVALUATION
type = float
required = false
default = 1.0
range = real
allowed = float
nuance = consumed as probe training clip threshold

[FIELD nll_eps]
key = nll_eps
scope = TRANSFER_MATRIX_EVALUATION
type = float
required = false
default = 1e-6
range = > 0 (fallback to default)
allowed = float
nuance = non-positive values are replaced by default

[FIELD nll_sigma_min]
key = nll_sigma_min
scope = TRANSFER_MATRIX_EVALUATION
type = float
required = false
default = 1e-3
range = >= 0 (clamped)
allowed = float
nuance = negative values clamp to 0

[FIELD nll_sigma_max]
key = nll_sigma_max
scope = TRANSFER_MATRIX_EVALUATION
type = float
required = false
default = 0.0
range = >= 0 (clamped)
allowed = float
nuance = zero means no upper clamp

[FIELD summary_every_steps]
key = summary_every_steps
scope = TRANSFER_MATRIX_EVALUATION
type = int
required = false
default = 64
range = >= 0 (clamped)
allowed = integer
nuance = zero disables periodic summary emission

[FIELD anchor_train_ratio]
key = anchor_train_ratio
scope = TRANSFER_MATRIX_EVALUATION
type = float
required = false
default = 0.70
range = [0,1] then normalized with val/test ratios
allowed = float
nuance = ratio triplet is clamped and then renormalized; degenerate sum<=0 falls back to 0.70/0.15/0.15

[FIELD anchor_val_ratio]
key = anchor_val_ratio
scope = TRANSFER_MATRIX_EVALUATION
type = float
required = false
default = 0.15
range = [0,1] then normalized with train/test ratios
allowed = float
nuance = ratio triplet is clamped and then renormalized

[FIELD anchor_test_ratio]
key = anchor_test_ratio
scope = TRANSFER_MATRIX_EVALUATION
type = float
required = false
default = 0.15
range = [0,1] then normalized with train/val ratios
allowed = float
nuance = ratio triplet is clamped and then renormalized

[FIELD prequential_blocks]
key = prequential_blocks
scope = TRANSFER_MATRIX_EVALUATION
type = int
required = false
default = 4
range = >= 2 (clamped)
allowed = integer
nuance = values <2 are replaced by 2

[FIELD linear_ridge_lambda]
key = linear_ridge_lambda
scope = TRANSFER_MATRIX_EVALUATION
type = float
required = false
default = 1e-3
range = >= 0 else fallback
allowed = float
nuance = negative values are reset to default

[FIELD gaussian_var_min]
key = gaussian_var_min
scope = TRANSFER_MATRIX_EVALUATION
type = float
required = false
default = 1e-6
range = > 0 else fallback
allowed = float
nuance = non-positive values are reset to default

[FIELD control_shuffle_block]
key = control_shuffle_block
scope = TRANSFER_MATRIX_EVALUATION
type = int
required = false
default = 16
range = >= 1 (clamped)
allowed = integer
nuance = values <1 are replaced by 1

[FIELD control_shuffle_seed]
key = control_shuffle_seed
scope = TRANSFER_MATRIX_EVALUATION
type = int
required = false
default = 1337
range = >= 0 (clamped)
allowed = integer
nuance = negative values are replaced by 0

[FIELD dtype]
key = dtype
scope = TRANSFER_MATRIX_EVALUATION
type = dtype token
required = false
default = module/runtime default resolution
range = known dtype tokens
allowed = bool,int8,int16,int32,int64,float16,half,f16,float32,float,f32,float64,double,f64 and torch::/at::/k-prefixed variants
nuance = token validated in contract layer and consumed by config_dtype

[FIELD device]
key = device
scope = TRANSFER_MATRIX_EVALUATION
type = device token
required = false
default = module/runtime default resolution
range = cpu or cuda-class token
allowed = cpu,cuda,gpu,cuda:<n>,gpu:<n>,torch::kcpu,torch::kcuda,kcpu,kcuda
nuance = CUDA unavailability or probe failure triggers CPU fallback warning

[RULE WAVE_POLICY_STRICT]
id = WAVE_POLICY_STRICT
applies_to = wave PROBE policy for transfer_matrix_evaluation
severity = error
when = TRAINING_WINDOW != incoming_batch or REPORT_POLICY != epoch_end_log or OBJECTIVE != future_target_dims_nll
message = transfer_matrix_eval accepts only one wave probe policy triplet

[RULE MODEL_SPEC_MINIMUM]
id = MODEL_SPEC_MINIMUM
applies_to = runtime model construction
severity = error
when = encoding_dims<=0 or channels<=0 or horizons<=0 or mixture_comps<=0 or features_hidden<=0 or residual_depth<0 or target_dims empty
message = transfer_matrix_eval invalid model specification from contract
