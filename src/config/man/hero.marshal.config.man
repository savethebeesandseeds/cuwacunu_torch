MAN_SPEC_VERSION = 1

[META]
MAN_ID = hero.marshal.config
TARGET_DSL = src/config/instructions/defaults/default.hero.marshal.dsl
TARGET_BNF = src/config/bnf/latent_lineage_state.authored.bnf
PRIMARY_DECODER = src/impl/camahjucunu/dsl/latent_lineage_state/latent_lineage_state.cpp
PRIMARY_VALIDATORS = src/main/hero/hero_marshal_mcp.cpp

[FIELD runtime_hero_binary]
key = runtime_hero_binary
scope = hero marshal defaults
type = path_or_command
required = true
default = /cuwacunu/.build/hero/hero_runtime_mcp
range = executable path or PATH-resolved command name
allowed = absolute_or_relative path or bare command token
nuance = Runtime Hero MCP binary that Marshal Hero uses to launch, inspect, and stop campaigns

[FIELD config_hero_binary]
key = config_hero_binary
scope = hero marshal defaults
type = path_or_command
required = true
default = /cuwacunu/.build/hero/hero_config_mcp
range = executable path or PATH-resolved command name
allowed = absolute_or_relative path or bare command token
nuance = Config Hero MCP binary attached to Codex planning checkpoints for bounded truth-source objective/default file mutation plus audited backups

[FIELD lattice_hero_binary]
key = lattice_hero_binary
scope = hero marshal defaults
type = path_or_command
required = true
default = /cuwacunu/.build/hero/hero_lattice_mcp
range = executable path or PATH-resolved command name
allowed = absolute_or_relative path or bare command token
nuance = Lattice Hero MCP binary attached to Codex planning checkpoints for fact/view inspection

[FIELD human_hero_binary]
key = human_hero_binary
scope = hero marshal defaults
type = path_or_command
required = true
default = /cuwacunu/.build/hero/hero_human_mcp
range = executable path or PATH-resolved command name
allowed = absolute_or_relative path or bare command token
nuance = Human Hero MCP binary Marshal Hero invokes when a planning checkpoint pauses for input or governance and must materialize or refresh the operator-facing request artifact

[FIELD human_operator_identities]
key = human_operator_identities
scope = hero marshal defaults
type = path
required = true
default = ../../secrets/real/human_operator_identities
range = readable operator identity map
allowed = absolute path or path resolved relative to default.hero.marshal.dsl
nuance = operator identities file Marshal Hero uses to bind Human Hero operator_id values to OpenSSH ssh-ed25519 public keys before applying a signed human resolution

[FIELD config_scope_root]
key = config_scope_root
scope = hero marshal defaults
type = path
required = true
default = ../..
range = writable config scope root
allowed = absolute path or path resolved relative to default.hero.marshal.dsl
nuance = config root Marshal Hero bakes into its session-local Config Hero policy instead of peeking into Config Hero defaults; the generated policy writes truth-source objective/default backups outside runtime state

[FIELD marshal_codex_binary]
key = marshal_codex_binary
scope = hero marshal defaults
type = path_or_command
required = true
default = codex
range = executable path or PATH-resolved command name
allowed = absolute_or_relative path or bare command token
nuance = Codex command used by Marshal Hero at each autonomous planning checkpoint

[FIELD marshal_codex_model]
key = marshal_codex_model
scope = hero marshal defaults
type = str
required = false
default = gpt-5.3-codex-spark
range = non-empty model slug
allowed = scalar string accepted by `codex exec -m`
nuance = default Codex model Marshal Hero uses for fresh and resumed planning checkpoints unless an older session record already persisted a resolved model

[FIELD marshal_codex_reasoning_effort]
key = marshal_codex_reasoning_effort
scope = hero marshal defaults
type = str
required = false
default = xhigh
range = one of `low`, `medium`, `high`, `xhigh`
allowed = scalar string normalized to Codex `model_reasoning_effort`
nuance = default Codex reasoning effort Marshal Hero passes through `-c model_reasoning_effort=...`; `xhigh` corresponds to Extra High reasoning

[FIELD tail_default_lines]
key = tail_default_lines
scope = hero marshal defaults
type = uint
required = true
default = 120
range = [1,+inf)
allowed = unsigned integer
nuance = default log/trace tail size used when Marshal Hero assembles input-checkpoint evidence for Codex

[FIELD poll_interval_ms]
key = poll_interval_ms
scope = hero marshal defaults
type = uint
required = true
default = 1000
range = [100,+inf)
allowed = unsigned integer
nuance = detached session-runner polling interval while waiting for the active Runtime campaign to reach a terminal state

[FIELD marshal_codex_timeout_sec]
key = marshal_codex_timeout_sec
scope = hero marshal defaults
type = uint
required = true
default = 900
range = [1,+inf)
allowed = unsigned integer
nuance = wall-clock timeout for one Codex planning/resume call within a Marshal Hero session

[FIELD marshal_max_campaign_launches]
key = marshal_max_campaign_launches
scope = hero marshal defaults
type = uint
required = true
default = 64
range = [1,+inf)
allowed = unsigned integer
nuance = hard upper bound on Runtime campaign launches within one Marshal Hero session before the session ends as exhausted
